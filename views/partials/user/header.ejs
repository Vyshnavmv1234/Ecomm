<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>WestLane</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <!-- header.ejs -->
<link rel="stylesheet" href="/css/base.css">
<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="/css/login.css" />
       
  <style>
    /* ===== CSS DROPDOWN ===== */

.dropdown {
  position: relative;
}

.dropdown-toggle {
  cursor: pointer;
  font-weight: 500;
}

.dropdown-menu {
  position: absolute;
  top: 130%;
  right: 0;
  min-width: 160px;
  background: #fff;
  border: 1px solid #e5e5e5;
  box-shadow: 0 8px 20px rgba(0,0,0,0.12);
  border-radius: 6px;
  padding: 8px 0;
  display: none;
  z-index: 2000;
}

.dropdown-menu a {
  display: block;
  padding: 10px 16px;
  font-size: 14px;
  color: #222;
  white-space: nowrap;
}

.dropdown-menu a:hover {
  background: #f5f5f5;
}
body{
  padding-top:120px;
}
    

    /* ---------------- HEADER ---------------- */
  header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background: #fff;
  border-bottom: 1px solid #eee;
  padding: 18px 60px;
  z-index: 1000;
}
    .cart-badge {
  position: absolute;
  top: -6px;
  right: -10px;
  background: #e63946;
  color: white;
  font-size: 9px;
  font-weight: 400;
  padding: 3px 6px;
  border-radius: 50%;
}

    .header-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-weight: 500;
    }

    .search {
      flex: 1;
      margin: 0 40px;
    }
    .dropdown:hover .dropdown-menu {
  display: block;
}


    .search input {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid #ddd;
      font-size: 14px;
    }

    .header-icons {
      display: flex;
      gap: 18px;
      font-size: 14px;
    }

    nav {
      margin-top: 16px;
      display: flex;
      justify-content: center;
      gap: 28px;
      font-size: 14px;
    }

   
  

  </style>
</head>
<body>

  <!-- HEADER -->
  <header>
    <div class="header-top">
      <div class="logo"><a href="/user/homepage">WestLane</a></div>
      
      <div class="search">
        <form method="get" action="/user/productList">
        <input 
        name="pSearch" 
        value="<%= typeof search !== 'undefined' ? search : '' %>" 
        type="text" 
        placeholder="What are you looking for?" 
      />
      </form>
      </div>
      <div class="header-icons">

        <% if (user) { %>

          <div class="dropdown">

  <span class="dropdown-toggle" id="userToggle">
    <%= user.name %> ▾
  </span> 

  <div class="dropdown-menu" id="userMenu">
    <a href="/user/userDashboard">My Profile</a>
    <a href="/user/logout">Logout</a>
  </div>

</div>
        <% } else { %>

        <a href="/user/signup">Sign up</a>
        <a href="/user/login">Log in</a>

        <% } %>

        <div style="position: relative; display:inline-block;">
      <a href="/user/wishlist">
        <i class="fa fa-heart"></i>
      </a>

      <span id="wishlistBadge" class="cart-badge"
            style="<%= wishlistCount > 0 ? '' : 'display:none' %>">
            <%= wishlistCount %>
      </span>
    </div>

        <div style="position: relative; display:inline-block;">
        <a href="/user/cart">
          <i class="fa fa-shopping-cart"></i>
        </a>

        <% if (cartCount > 0) { %>
          <span class="cart-badge"><%= cartCount %></span>
        <% } %>
      </div>
      </div>
    </div>
    <nav>

<a href="/user/productList">All</a>

<% if(category && category.length > 0){ %>

  <% category.forEach(cat => { %>

    <a href="/user/productList?category=<%= cat._id %>">
      <%= cat.name %>
    </a>

  <% }) %>

<% } %>

</nav>
  </header>

  <script>
  const toggle = document.getElementById("userToggle");
  const menu = document.getElementById("userMenu");

  if (toggle) {

    let isOpenByClick = false;

    toggle.addEventListener("click", function (e) {
      e.stopPropagation();
      isOpenByClick = !isOpenByClick;
      menu.style.display = isOpenByClick ? "block" : "none";
    });

    document.addEventListener("click", function () {
      isOpenByClick = false;
      menu.style.display = "none";
    });

  }

  async function addToWishlist(productId, variantId) {

  const res = await fetch("/user/wishlist", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ productId, variantId })
  });

  const data = await res.json();

  if (data.success) {
    updateWishlistBadge(data.wishlistCount);
  }

}

  function updateWishlistBadge(count) {

  const badge = document.getElementById("wishlistBadge");

  if (!badge) return;

  if (count > 0) {
    badge.style.display = "block";
    badge.textContent = count;
  } else {
    badge.style.display = "none";
  }

}
</script>


  