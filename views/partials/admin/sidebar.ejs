  }

  .sidebar-menu a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 12px;
    text-decoration: none;
    color: #64748b;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sidebar-menu a i {
    font-size: 18px;
    width: 24px;
    text-align: center;
    color: #94a3b8;
    transition: all 0.2s ease;
  }

  .sidebar-menu a:hover {
    background: #f8fafc;
    color: #4361ee;
  }

  .sidebar-menu a:hover i {
