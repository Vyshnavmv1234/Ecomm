    transform: translateX(5px);
  }
</style>

<script>
  // Automatically highlight active sidebar item
  document.addEventListener('DOMContentLoaded', () => {
    const currentPath = window.location.pathname;
    const menuLinks = document.querySelectorAll('.sidebar-menu a');
    
    menuLinks.forEach(link => {
      const linkPath = link.getAttribute('data-path');
      if (currentPath === linkPath || currentPath.startsWith(linkPath + '/')) {
        link.classList.add('active');
        // If it's a subpage, highlight the parent category
        const sectionTitle = link.closest('.sidebar-section').querySelector('.section-title');
        if (sectionTitle) sectionTitle.style.color = '#4361ee';
      }
    });
  });
</script>
