  <%-include("../../views/partials/user/header")%>


<!-- ================= MAIN ================= -->
<main style="padding:50px 60px;">

  <h2 style="text-align:center; margin-bottom:40px;">
    Hello, <%=user.name%>
  </h2>

  <div style="display:flex; gap:40px; align-items:flex-start;">

    <!-- ========== SIDEBAR ========== -->

      <%-include("../../views/partials/user/sidebar")%>

    

    <!-- ========== CONTENT ========== -->
    <section style="flex:1; display:flex; flex-direction:column; gap:30px;">

      <!-- ACCOUNT INFO + ADDRESS -->
      <div style="display:flex; gap:30px;">

        <!-- ACCOUNT INFO -->
        <div style="flex:1; background:#fff; border-radius:8px; padding:25px; border:1px solid #e5e5e5;">
          <h4 style="margin-bottom:20px;">ACCOUNT INFO</h4>

          <div style="display:flex; gap:20px; align-items:center;">
            <div style="width:60px; height:60px; background:#d9d9d9; border-radius:50%;"></div>

            <div>
              <p style="margin:0; font-weight:500;"><%=user.name%></p>
              <p style="margin:6px 0 0; font-size:14px; color:#666;">
                Email: <%=user.email%>
              </p>
            </div>
          </div>

          <button style="margin-top:25px; padding:8px 18px; border:1px solid #2bb0c0; background:#fff; color:#2bb0c0; border-radius:6px;">
            <a href="/user/userProfile">Edit Account</a>
          </button>
        </div>
        <!-- REFERRAL SECTION -->
<div style="
  background:#fff;
  border-radius:8px;
  padding:25px;
  border:1px solid #e5e5e5;
">

  <h4 style="margin-bottom:15px;">Invite & Earn</h4>

  <p style="font-size:14px; color:#666;">
    Share your referral code and earn rewards when your friends join!
  </p>

  <!-- Referral Code -->
  <div style=" margin-top:15px;">
    <label style="font-size:13px;">Your Referral Code</label>

    <div style="display:flex; gap:10px; margin-top:6px;">
      <input
        id="referralCode"
        type="text"
        value="<%= user.referralCode %>"
        readonly
        style="
          flex:1;
          padding:8px;
          border:1px solid #ddd;
          border-radius:6px;
        "
      >

      <button onclick="copyReferralCode()"
        style="
          padding:8px 15px;
          background:#2bb0c0;
          color:white;
          border:none;
          border-radius:6px;
          cursor:pointer;
        ">
        Copy
      </button>
    </div>
  </div>

</div>

    </section>
  </div>
</main>
<script>
  function copyReferralCode(){

  const code =
    document.getElementById("referralCode");

  code.select();
  document.execCommand("copy");

  
}
</script>

  <%-include("../../views/partials/user/footer")%>
