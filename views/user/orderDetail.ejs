<%- include("../../views/partials/user/header") %>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Segoe UI", sans-serif;
  }

  body {
    background: #f6f6f6;
  }
  /* ===== STATUS BADGES ===== */

  /* ===== MODAL DROPDOWN ===== */

.status-select {
  width: 100%;
  padding: 12px 14px;
  margin-bottom: 14px;
  border-radius: 8px;
  border: 1px solid #ddd;
  font-size: 14px;
  background-color: #fff;
  color: #333;
  cursor: pointer;
  outline: none;
  transition: all 0.2s ease;

  /* Remove default arrow */
  appearance: none;
  -webkit-appearance: none;
  -moz-appearance: none;

  /* Custom arrow */
  background-image: url("data:image/svg+xml;utf8,<svg fill='%236b7280' height='20' viewBox='0 0 24 24' width='20' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/></svg>");
  background-repeat: no-repeat;
  background-position: right 12px center;
  background-size: 18px;
}

/* Hover */
.status-select:hover {
  border-color: #bbb;
}
/* ===== RETRY PAYMENT BUTTON ===== */

.retry {
  padding: 10px 20px;
  border-radius: 8px;
  border: none;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  background: linear-gradient(135deg, #111827, #1f2937);
  color: #ffffff;
  box-shadow: 0 6px 18px rgba(0,0,0,0.12);
  transition: all 0.25s ease;
}

/* Hover */
.retry:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 22px rgba(0,0,0,0.18);
  background: linear-gradient(135deg, #000000, #111827);
}

/* Click effect */
.retry:active {
  transform: scale(0.97);
}

/* Focus */
.status-select:focus {
  border-color: #ff4d4d;
  box-shadow: 0 0 0 3px rgba(255, 77, 77, 0.1);
}

.status-badge {
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  border: none;
  cursor: default;
  display: inline-block;
  text-align: center;
  min-width: 90px;
}

/* Returned */
.status-returned {
  background: #fee2e2;
  color: #dc2626;
}

/* Cancelled */
.status-cancelled {
  background: #fef3c7;
  color: #d97706;
}

/* Requested */
.status-requested {
  background: #e0f2fe;
  color: #0284c7;
}

/* Approved */
.status-approved {
  background: #dcfce7;
  color: #16a34a;
}

/* Return Closed */
.status-closed {
  background: #f3f4f6;
  color: #6b7280;
}

/* Action buttons hover */
.return-btn:hover {
  background: #e63e3e;
  transition: 0.3s ease;
}

.submit-btn:hover {
  background: #218838;
  transition: 0.3s ease;
}

  .return-btn {
  padding: 8px 16px;
  background: #ff4d4d;
  color: white;
  border: none;
  border-radius: 4px;
  cursor: pointer;
}

.modal {
  display: none;
  position: fixed;
  z-index: 999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  background: #fff;
  width: 400px;
  margin: 15% auto;
  padding: 20px;
  border-radius: 8px;
  position: relative;
}

.modal-content h3 {
  margin-bottom: 10px;
}

.modal-content textarea {
  width: 100%;
  height: 80px;
  padding: 10px;
  resize: none;
  margin-bottom: 15px;
}

.submit-btn {
  width: 100%;
  padding: 10px;
  background: #28a745;
  color: white;
  border: none;
  border-radius: 4px;
}

.close {
  position: absolute;
  top: 10px;
  right: 15px;
  font-size: 22px;
  cursor: pointer;
}


  .order-container {
    max-width: 1200px;
    margin: 40px auto 80px;
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    padding: 30px;
  }

  /* Header */
  .order-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #eee;
    padding-bottom: 20px;
  }

  .order-header h3 {
    font-size: 16px;
    font-weight: 600;
  }

  .order-header a {
    font-size: 14px;
    color: #ff4d4f;
    text-decoration: none;
  }

  /* Summary */
  .order-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #f9f9f9;
    padding: 20px;
    border-radius: 8px;
    margin-top: 25px;
  }

  .order-summary p {
    font-size: 14px;
    color: #555;
  }

  .order-summary h2 {
    font-size: 22px;
  }

  /* Timeline */
  .timeline {
    margin: 30px 0 40px;
  }

  .progress {
    display: flex;
    justify-content: space-between;
    position: relative;
  }

  .progress::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 4px;
    background: #e0e0e0;
  }

  .step {
    text-align: center;
    width: 25%;
    position: relative;
    z-index: 1;
  }

  .step span {
    display: inline-block;
    width: 18px;
    height: 18px;
    background: #ff8a3d;
    border-radius: 50%;
    margin-bottom: 6px;
  }

  .step p {
    font-size: 13px;
    color: #555;
  }

  /* ===== MAIN GRID ===== */
  .order-main-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 30px;
    margin-top: 30px;
  }

  /* ===== PRODUCTS (LEFT) ===== */
  .product-section h4 {
    font-size: 18px;
    margin-bottom: 15px;
  }

  .product-row {
    display: flex;
    align-items: center;
    border-top: 1px solid #eee;
    padding: 20px 0;
  }

  .product-row img {
    width: 80px;
    margin-right: 20px;
  }

  .product-info {
    flex: 1;
  }

  .product-info small {
    font-size: 12px;
    color: #888;
  }

  .product-info p {
    font-size: 14px;
    margin-top: 4px;
  }

  .product-qty,
  .product-price {
    width: 120px;
    text-align: center;
    font-size: 14px;
  }
  .stat{
    width: 120px;
    text-align: center;
    font-size: 14px;
  }

  /* ===== RIGHT PANEL ===== */
  .right-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .address-section,
  .price-details {
    background: #fff;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.06);
  }

  .address-section h4,
  .price-details h4 {
    font-size: 18px;
    margin-bottom: 14px;
  }

  .address-box {
    font-size: 14px;
    line-height: 1.6;
    color: #555;
  }

  /* Price */
  .price-details {
    display: flex;
    flex-direction: column;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    margin-bottom: 10px;
  }

  .price-row.total {
    font-weight: 600;
    font-size: 16px;
  }

  .discount {
    color: #16a34a;
  }

  .price-details hr {
    border: none;
    border-top: 1px dashed #ddd;
    margin: 12px 0;
  }

  .invoice-btn {
    margin-top: 10px;
    padding: 10px;
    width: 100%;
    border-radius: 8px;
    border: 1px solid #ddd;
    background: #fff;
    cursor: pointer;
  }

</style>

<div class="order-container">

  <!-- ================= HEADER ================= -->
  <div class="order-header">
    <h3>← ORDER DETAILS</h3>

    <% if (order.status === "cancelled") { %>

      <p style="color: red;">Cancelled</p>

    <% } else if (
         order.paymentMethod === "RAZORPAY" &&
         order.paymentStatus === "pending"
    ) { %>

      <button class="retry" onclick="retryPayment()">Retry Payment</button>

    <% } else if (
         order.status === "delivered" &&
         order.orderItems.some(i => i.status === "delivered")&&!order.returnExpired
    ) { %>
      <% if (order.returnExpired) { %>
  <p style="color: gray;">Return window closed</p>
<% } %>

      <!-- Show return only if at least one item is delivered -->
      <button class="return-btn"
              onclick="openReturnModal('<%= order._id %>')">
        Return Order
      </button>

    <% } else if (
         order.status !== "returned" &&
         order.status !== "cancelled" &&
         order.status !== "delivered"
    ) { %>

      <button onclick="openCancelModal('<%=orderId%>', null)">
        Cancel Order
      </button>

    <% } %>
  </div>


  <!-- ================= SUMMARY ================= -->
  <div class="order-summary">
    <div>
      <p><strong><%= orderId %></strong></p>
      <p>Order Placed on: <b><%= order.formattedDate %></b></p>
      <p>Order Status: <b><%= order.status %></b></p>
    </div>
    <h2>₹<%= order.orderSummary.total %></h2>
  </div>


  <!-- ================= MAIN GRID ================= -->
  <div class="order-main-grid">

    <!-- ================= LEFT: PRODUCTS ================= -->
    <div class="product-section">
      <h4>Products</h4>

      <% order.orderItems.forEach(item => { %>

        <div class="product-row">

          <a href="/user/productDetail?id=<%=item.product._id%>">
            <img src="<%= item.product.images[0].url %>" alt="">
          </a>

          <div class="product-info">
            <small><%= item.product.title %></small>
            <p><%= item.product.name%>  (<%=item.selectedVariant.size%>) </p>
          </div>

          <div class="product-qty">
            x<%= item.quantity %>
          </div>

          <div class="product-price">
            ₹<%= item.originalPrice * item.quantity %>
          </div>


          <% if (item.status === "returned") { %>

              <div class="stat">
                <span class="status-badge status-returned">
                Returned
              </span>
              </div>

          <% } else if (item.status === "cancelled") { %>

              <div class="stat">
                <span class="status-badge status-cancelled">
                Cancelled
              </span>
              </div>

          <% } else if (item.returnRequested) { %>

              <div class="stat">
                <span class="status-badge status-requested">
                Return Requested
              </span>
              </div>

          <% } else if (
                item.status === "placed" &&
                order.status !== "delivered"
          ) { %>

              <button onclick="openCancelModal('<%=orderId%>','<%=item._id%>')">
                Cancel
              </button>

          <% } else if (item.status === "delivered"&&!order.returnExpired) { %>

              <button class="return-btn"
                      onclick="openReturnItemModal('<%=item._id%>','<%=order._id%>')">
                Return
              </button>

          <% } %>

        </div>

      <% }) %>

    </div>


    <!-- ================= RIGHT PANEL ================= -->
    <div class="right-panel">

      <!-- ADDRESS -->
      <div class="address-section">
        <h4>Address</h4>
        <div class="address-box">
          <strong><%= order.shipping_address.name %></strong><br>
          <%= order.shipping_address.house %>,<br>
          <%= order.shipping_address.streetName %><br>
          <%= order.shipping_address.city %>,<br>
          <%= order.shipping_address.state %> – 
          <%= order.shipping_address.pincode %><br><br>
          Phone: <%= order.shipping_address.phone %><br>
          Email: <%= order.shipping_address.email || "N/A" %>
        </div>
      </div>


      <!-- PRICE DETAILS -->
      <div class="price-details">
        <h4>Price Details</h4>

        <div class="price-row">
          <span>Sub-Total</span>
          <span>₹<%= order.orderSummary.subTotal %></span>
        </div>

        <div class="price-row">
          <span>Discount</span>
          <span class="discount">
            -₹<%= (order.orderSummary.discount || 0) + 
                  (order.orderSummary.coupon || 0) %>
          </span>
        </div>

        <div class="price-row">
          <span>GST</span>
          <span>+₹<%= order.orderSummary.GST || 0 %></span>
        </div>

        <div class="price-row">
          <span>Shipping</span>
          <span>Free</span>
        </div>

        <hr>

        <div class="price-row total">
          <span>Total amount</span>
          <span>₹<%= order.orderSummary.total %></span>
        </div>

        <% if(order.status === "delivered") { %>
          <a href="/user/order/<%= order._id %>/invoice">
            <button class="invoice-btn">⬇ Download Invoice</button>
          </a>
        <% } %>

      </div>
    </div>
  </div>
</div>
<!-- Order Return Modal -->
<div id="returnModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeReturnModal()">&times;</span>

    <h3>Request Return (Full Order)</h3>

    <form action="/user/request-return" method="POST">
      <input type="hidden" name="orderId" id="modalOrderId">

      <textarea
        name="reason"
        required
        placeholder="Please tell us the reason for return..."
      ></textarea>

      <button type="submit" class="submit-btn">
        Submit Request
      </button>
    </form>
  </div>
</div>
<!-- Item Return Modal -->
<div id="returnItemModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeReturnItemModal()">&times;</span>

    <h3>Request Return (Item)</h3>

    <form action="/user/request-returnItem" method="POST">
      <input type="hidden" name="orderItemId" id="modalItemOrderId">
      <input type="hidden" name="orderId" id="orderId">

      <textarea
        name="reason"
        required
        placeholder="Please tell us the reason for return..."
      ></textarea>

      <button type="submit" class="submit-btn">
        Submit Request
      </button>
    </form>
  </div>
</div>
<!-- Cancel Reason Modal -->
<div id="cancelModal" class="modal">
  <div class="modal-content">

    <span class="close" onclick="closeCancelModal()">&times;</span>

    <h3>Select Cancellation Reason</h3>

    <input type="hidden" id="cancelOrderId">
    <input type="hidden" id="cancelItemId">

    <select id="cancelReason" class="status-select">
      <option value="">-- Select Reason --</option>
      <option>Ordered by mistake</option>
      <option>Found cheaper elsewhere</option>
      <option>Delivery taking too long</option>
      <option>Change in delivery address</option>
      <option>Product not required anymore</option>
    </select>

    <textarea
      id="cancelComment"
      placeholder="Additional comment (optional)"
    ></textarea>

    <button class="submit-btn" onclick="submitCancellation()">
      Confirm Cancellation
    </button>

  </div>
</div>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>

  function openCancelModal(orderId, itemId = null) {

  document.getElementById("cancelOrderId").value = orderId;
  document.getElementById("cancelItemId").value = itemId || "";

  document.getElementById("cancelModal").style.display = "block";
}

function closeCancelModal() {
  document.getElementById("cancelModal").style.display = "none";
}

  async function submitCancellation() {

  const orderId = document.getElementById("cancelOrderId").value;
  const itemId = document.getElementById("cancelItemId").value;
  const reason = document.getElementById("cancelReason").value;
  const comment = document.getElementById("cancelComment").value;

  if (!reason) {
    Toastify({
      text: "Please select a reason",
      duration: 2500,
      gravity: "top",
      position: "right",
      backgroundColor: "#dc3545"
    }).showToast();
    return;
  }

  const url = itemId
    ? "/user/cancelProduct"
    : "/user/cancelOrder";

  const body = itemId
    ? { orderId, itemId, reason, comment }
    : { orderId, reason, comment };

  const res = await fetch(url, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(body)
  });

  const data = await res.json();

  if (data.success) {

    Toastify({
      text: "Order cancelled successfully",
      duration: 2500,
      gravity: "top",
      position: "right",
      backgroundColor: "#28a745"
    }).showToast();

    setTimeout(() => location.reload(), 1200);

  } else {
    Toastify({
      text: data.message || "Cancellation failed",
      duration: 2500,
      gravity: "top",
      position: "right",
      backgroundColor: "#dc3545"
    }).showToast();
  }

  closeCancelModal();
}
function closeReturnItemModal() {
  document.getElementById("returnItemModal").style.display = "none";
}

  function openReturnModal(orderId) {
    document.getElementById("modalOrderId").value = orderId;
    document.getElementById("returnModal").style.display = "block";
  }
  function openReturnItemModal(itemId,orderId) {
    document.getElementById("modalItemOrderId").value = itemId;
    document.getElementById("orderId").value = orderId;
    document.getElementById("returnItemModal").style.display = "block";
  }

  function closeReturnModal() {
    document.getElementById("returnModal").style.display = "none";
  }

  window.onclick = function (event) {
  const orderModal = document.getElementById("returnModal");
  const itemModal = document.getElementById("returnItemModal");
  const cancelModal = document.getElementById("cancelModal");

  if (event.target === orderModal) closeReturnModal();
  if (event.target === itemModal) closeReturnItemModal();
  if (event.target === cancelModal) closeCancelModal();
};

async function retryPayment() {

  const amount = "<%= order.orderSummary.total %>";
  const dbOrderId = "<%= order._id %>";

  try {

    const razorRes = await fetch("/user/create-razorpay-order", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        amount,
        dbOrderId
      })
    });

    if (!razorRes.ok) {
      throw new Error("Razor order creation failed");
    }

    const razorData = await razorRes.json();

    const rzp = new Razorpay({
      key: "<%= process.env.RAZORPAY_KEY_ID %>",
      amount: razorData.amount,
      currency: "INR",
      order_id: razorData.id,

      handler: async function (response) {

        const verifyRes = await fetch("/user/verify-payment", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            ...response,
            dbOrderId
          })
        });

        const verifyData = await verifyRes.json();

        if (!verifyData.success) {
          alert("Payment verification failed.");
          return;
        }

        window.location.href = `/user/order/${dbOrderId}`;
      }
    });

    rzp.open();

  } catch (err) {
    console.error("Retry error:", err);
    alert("Something went wrong while retrying payment");
  }
}</script>

<%- include("../../views/partials/user/footer") %>
