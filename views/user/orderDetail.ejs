<%- include("../../views/partials/user/header") %>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Segoe UI", sans-serif;
  }

  body {
    background: #f6f6f6;
  }

  .order-container {
    max-width: 1200px;
    margin: 40px auto 80px;
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    padding: 30px;
  }

  /* Header */
  .order-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #eee;
    padding-bottom: 20px;
  }

  .order-header h3 {
    font-size: 16px;
    font-weight: 600;
  }

  .order-header a {
    font-size: 14px;
    color: #ff4d4f;
    text-decoration: none;
  }

  /* Summary */
  .order-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #f9f9f9;
    padding: 20px;
    border-radius: 8px;
    margin-top: 25px;
  }

  .order-summary p {
    font-size: 14px;
    color: #555;
  }

  .order-summary h2 {
    font-size: 22px;
  }

  /* Timeline */
  .timeline {
    margin: 30px 0 40px;
  }

  .progress {
    display: flex;
    justify-content: space-between;
    position: relative;
  }

  .progress::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 4px;
    background: #e0e0e0;
  }

  .step {
    text-align: center;
    width: 25%;
    position: relative;
    z-index: 1;
  }

  .step span {
    display: inline-block;
    width: 18px;
    height: 18px;
    background: #ff8a3d;
    border-radius: 50%;
    margin-bottom: 6px;
  }

  .step p {
    font-size: 13px;
    color: #555;
  }

  /* ===== MAIN GRID ===== */
  .order-main-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 30px;
    margin-top: 30px;
  }

  /* ===== PRODUCTS (LEFT) ===== */
  .product-section h4 {
    font-size: 18px;
    margin-bottom: 15px;
  }

  .product-row {
    display: flex;
    align-items: center;
    border-top: 1px solid #eee;
    padding: 20px 0;
  }

  .product-row img {
    width: 80px;
    margin-right: 20px;
  }

  .product-info {
    flex: 1;
  }

  .product-info small {
    font-size: 12px;
    color: #888;
  }

  .product-info p {
    font-size: 14px;
    margin-top: 4px;
  }

  .product-qty,
  .product-price {
    width: 120px;
    text-align: center;
    font-size: 14px;
  }

  /* ===== RIGHT PANEL ===== */
  .right-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .address-section,
  .price-details {
    background: #fff;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.06);
  }

  .address-section h4,
  .price-details h4 {
    font-size: 18px;
    margin-bottom: 14px;
  }

  .address-box {
    font-size: 14px;
    line-height: 1.6;
    color: #555;
  }

  /* Price */
  .price-details {
    display: flex;
    flex-direction: column;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    margin-bottom: 10px;
  }

  .price-row.total {
    font-weight: 600;
    font-size: 16px;
  }

  .discount {
    color: #16a34a;
  }

  .price-details hr {
    border: none;
    border-top: 1px dashed #ddd;
    margin: 12px 0;
  }

  .invoice-btn {
    margin-top: 10px;
    padding: 10px;
    width: 100%;
    border-radius: 8px;
    border: 1px solid #ddd;
    background: #fff;
    cursor: pointer;
  }

</style>

<div class="order-container">

  <!-- Header -->
  <div class="order-header">
    <h3>← ORDER DETAILS</h3>
    <a href="#">Cancel Order</a>
  </div>

  <!-- Summary -->
  <div class="order-summary">
    <div>
      <p><strong><%= orderId %></strong></p>
      <p>Order Placed on <%= order.createdAt %></p>
    </div>
    <h2>₹<%= order.order_total %></h2>
  </div>

  <!-- Timeline -->
  <div class="timeline">
    <div class="progress">
      <div class="step"><span></span><p>Order Placed</p></div>
      <div class="step"><span></span><p>Packaging</p></div>
      <div class="step"><span></span><p>On The Road</p></div>
      <div class="step"><span></span><p>Delivered</p></div>
    </div>
  </div>

  <!-- MAIN GRID -->
  <div class="order-main-grid">

    <!-- LEFT: PRODUCTS -->
    <div class="product-section">
      <h4>Product</h4>

      <% order.orderItems.forEach(item => { %>
        <div class="product-row">
          <img src="<%= item.product.images[0].url %>" alt="">
          <div class="product-info">
            <small><%= item.product.category %></small>
            <p><%= item.product.name %></p>
          </div>
          <div class="product-qty">x<%= item.quantity %></div>
          <div class="product-price">₹<%= item.price * item.quantity %></div>
          <div class="product-price">Cancel</div>
        </div>
      <% }) %>
    </div>

    <!-- RIGHT: ADDRESS + PRICE -->
    <div class="right-panel">

      <div class="address-section">
        <h4>Address</h4>
        <div class="address-box">
          <strong><%= order.shipping_address.name %></strong><br>
          <%= order.shipping_address.house %>,<br>
          <%= order.shipping_address.streetName %><br>
          <%= order.shipping_address.city %>,<br>
          <%= order.shipping_address.state %> – <%= order.shipping_address.pincode %><br><br>
          Phone: <%= order.shipping_address.phone %><br>
          Email: <%= order.shipping_address.email || "N/A" %>
        </div>
      </div>

      <div class="price-details">
        <h4>Price Details</h4>

        <div class="price-row">
          <span>Sub-Total</span>
          <span>₹<%=orderSummary.subTotal %></span>
        </div>

        <div class="price-row">
          <span>Discount</span>
          <span class="discount">-₹<%= orderSummary.totalDiscount || 0 %></span>
        </div>

        <div class="price-row">
          <span>Shipping</span>
          <span>Free</span>
        </div>

        <hr>

        <div class="price-row total">
          <span>Total amount</span>
          <span>₹<%= order.order_total %></span>
        </div>

        <button class="invoice-btn">⬇ Download Invoice</button>
      </div>

    </div>
  </div>

</div>

<%- include("../../views/partials/user/footer") %>
