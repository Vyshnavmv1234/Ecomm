<%- include("../../views/partials/user/header") %>

<style>
  /* ===== HOME PAGE SPECIFIC ===== */

  /* ---- HERO BANNER: Full-bleed, tall, visually distinct ---- */
  .hero-banner {
  width: 100%;
  overflow: hidden;
  margin-bottom: 20px;
}

  .hero-banner img {
  width: 100%;
  height: 480px;
  object-fit: cover;
  object-position: 50% 30%;
}

  /* ---- Secondary hero (Celebrity section) ---- */
  .hero-secondary {
    width: 100%;
    overflow: hidden;
    margin: 0;
  }

  .hero-secondary img {
    width: 100%;
    height: 340px;
    object-fit: cover;
    display: block;
  }

  /* ---- Section labels ---- */
  .section-title {
    padding: 36px 40px 14px;
    font-size: 13px;
    letter-spacing: 2px;
    color: #888;
    text-transform: uppercase;
  }

  /* ---- Explore link ---- */
  .explore {
    text-align: center;
    margin: 32px 0 20px;
    font-size: 15px; /* larger feel */
    letter-spacing: 1.5px;
    font-weight: 500;
  }

  /* ---- Product grid ---- */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 24px;
    padding: 20px 40px 60px; /* refined padding */
  }

  .product-card {
    font-size: 13px;
  }

  /* Consistent image container — aspect-ratio enforced */
  .product-card .card-img-wrap {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f5f5f5;
    border-radius: 4px;
  }

  .product-card .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* fill the box completely to fix "zoomed out" feel */
    display: block;
    transition: transform 0.3s ease;
  }

  .product-card .card-img-wrap img:hover {
    transform: scale(1.05); /* more impactful hover */
  }

  .product-card p {
    margin-top: 10px;
    color: #555;
    font-size: 13px;
  }

  /* ---- Info strip ---- */
  .info {
    background: #f7f7f7;
    padding: 60px 40px;
    text-align: center;
  }

  .info h3 {
    font-size: 22px;
    margin-bottom: 14px;
    font-weight: normal;
  }

  .info > p {
    max-width: 600px;
    margin: 0 auto 36px;
    font-size: 16px; /* larger text */
    color: #666;
    line-height: 1.6;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 24px;
    font-size: 13px;
    color: #555;
  }

  /* ---- Mobile overrides (responsive.css handles breakpoints,
          these are home-page-specific fine-tuning) ---- */
  @media (max-width: 768px) {
    .hero-banner img { height: 220px; }
    .hero-secondary img { height: 160px; }
    .section-title { padding: 20px 14px 10px; font-size: 12px; }
    .explore { margin: 20px 0 8px; }
    .product-grid { padding: 0 10px 28px; gap: 12px; }
    .info { padding: 32px 14px; }
  }

  @media (max-width: 480px) {
    .hero-banner img { height: 180px; }
    .hero-secondary img { height: 130px; }
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      padding: 0 10px 20px;
    }
    .info-grid {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
  }
</style>


