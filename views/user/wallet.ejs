  <%-include("../../views/partials/user/header")%>

    <title>Wallet</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
        }

        .container {
            width: 90%;
            margin: 40px auto;
            display: flex;
            gap: 30px;
        }


        /* Wallet Content */
        .wallet-content {
            flex: 1;
        }

        .wallet-card {
            background: #fff;
            padding: 25px;
            border-radius: 6px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .wallet-balance {
            font-size: 32px;
            font-weight: bold;
        }

        .wallet-text {
            color: #777;
        }

        .add-money-btn {
            background-color: #4ea7a6;
            color: #fff;
            border: none;
            padding: 12px 20px;
            border-radius: 6px;
            cursor: pointer;
        }

        .add-money-btn:hover {
            background-color: #3d8f8e;
        }

        /* Transaction Table */
        .transaction-box {
            margin-top: 30px;
            background: #fff;
            padding: 20px;
            border-radius: 6px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .transaction-box h3 {
            margin-bottom: 15px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }

        th {
            background: #f8f8f8;
        }

        .pagination {
            text-align: center;
            margin-top: 20px;
        }

        .pagination button {
            padding: 6px 10px;
            margin: 0 5px;
            border-radius: 50%;
            border: 1px solid #ccc;
            background: #fff;
            cursor: pointer;
        }

        .pagination button.active {
            background: #d9c6c6;
        }
    </style>
</head>

<body>

<div class="container">

    <!-- Sidebar -->
  <%-include("../../views/partials/user/sidebar")%>


    <!-- Wallet Content -->
    <div class="wallet-content">

        <!-- Wallet Balance Card -->
        <div class="wallet-card">
            <div>
                <div class="wallet-balance">₹16,000</div>
                <div class="wallet-text">My Wallet Balance</div>
            </div>
            <button class="add-money-btn">Add Money</button>
        </div>

        <!-- Transactions -->
        <div class="transaction-box">
            <h3>TRANSACTION DETAILS</h3>

            <table>
                <thead>
                    <tr>
                        <th>Transaction ID</th>
                        <th>Description</th>
                        <th>Date</th>
                        <th>Withdrawal</th>
                        <th>Deposit</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>#96459761</td>
                        <td>You Added</td>
                        <td>Dec 30, 2023</td>
                        <td>₹6,000</td>
                        <td>-</td>
                    </tr>
                    <tr>
                        <td>#96459760</td>
                        <td>You Added</td>
                        <td>Dec 30, 2023</td>
                        <td>₹10,000</td>
                        <td>-</td>
                    </tr>
                    <tr>
                        <td>#96459759</td>
                        <td>Bought a product</td>
                        <td>Dec 30, 2023</td>
                        <td>-</td>
                        <td>₹3,600</td>
                    </tr>
                </tbody>
            </table>

            <div class="pagination">
                <button>&lt;</button>
                <button class="active">01</button>
                <button>02</button>
                <button>03</button>
                <button>&gt;</button>
            </div>

        </div>

    </div>

</div>

  <%-include("../../views/partials/user/footer")%>

