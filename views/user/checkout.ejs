<%- include("../../views/partials/user/header") %>

<style>


body {
  margin: 0;
  background: #f7f7f7;
  color: #222;
}
/* Address list */
.address-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 12px;
}

/* Address card */
.address-option {
  display: flex;
  gap: 14px;
  padding: 14px;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  cursor: pointer;
  align-items: center;   /* 🔥 FIX: center vertically */
}
.address-option input[type="radio"] {
  margin: 0;
  transform: translateY(2px); /* subtle optical alignment */
}
.address-option input[type="radio"]:checked + .address-text {
  font-weight: 500;
}

.address-option:has(input[type="radio"]:checked) {
  border-color: #2563eb;
  background: #eff6ff;
}


.address-option:hover {
  border-color: #2563eb;
}

/* Radio alignment */
.address-option input[type="radio"] {
  margin-top: 4px;
}

/* Text */
.address-text p {
  margin: 4px 0 0;
  font-size: 14px;
  color: #555;
}

/* Button row */
.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 20px;
}

/* Buttons */
.btn {
  padding: 10px 18px;
  border-radius: 6px;
  font-size: 14px;
  cursor: pointer;
  border: none;
}

.btn-primary {
  background-color: #2563eb;
  color: #fff;
}

.btn-primary:hover {
  background-color: #1d4ed8;
}

.btn-secondary {
  background-color: #f3f4f6;
  color: #111;
}

.btn-secondary:hover {
  background-color: #e5e7eb;
}

.address-modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.4);
  display: none;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #fff;
  padding: 20px;
  width: 400px;
  border-radius: 8px;
}

.address-option {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
  cursor: pointer;
}


.change-address-btn {
  margin-left: 12px;
  display: flex;
  justify-content: end;
  background: none;
  border: none;
  color: #2563eb;
  cursor: pointer;
  font-size: 14px;
}

/* ---------- MAIN ---------- */
.container {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 30px;
  padding: 40px;
}

/* ---------- FORM ---------- */
.card {
  background: #fff;
  padding: 30px;
  border-radius: 6px;
}

.card h2 {
  margin-bottom: 20px;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 15px;
}

.form-row.full {
  grid-template-columns: 1fr;
}

input, select {
  width: 100%;
  padding: 12px;
  border: 1px solid #ddd;
  border-radius: 4px;
}

label {
  font-size: 14px;
  margin-bottom: 6px;
  display: block;
}



/* ---------- PAYMENT ---------- */
.payment {
  margin-top: 30px;
}

.payment-options {
  display: flex;
  justify-content: space-between;
  margin-top: 20px;
}

.payment-box {
  flex: 1;
  text-align: center;
  padding: 20px;
  border-right: 1px solid #ddd;
}

.payment-box:last-child {
  border-right: none;
}

/* ---------- ORDER SUMMARY ---------- */
.summary {
  background: #fff;
  padding: 25px;
  border-radius: 6px;
}

.summary h3 {
  margin-bottom: 20px;
}
.default-address-row {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 14px;
  cursor: pointer;
}
/* FIX checkbox alignment */
input[type="checkbox"] {
  width: auto;
  padding: 0;
}


.default-address-row input {
  margin: 0;
}


.product {
  display: flex;
  gap: 15px;
  margin-bottom: 15px;
}
.product img {
  width: 60px;
  height: 60px;
  object-fit: cover;
  border-radius: 4px;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  margin: 10px 0;
  font-size: 14px;
}

.summary-total {
  font-weight: bold;
  font-size: 18px;
  margin-top: 15px;
}

.place-order {
  margin-top: 20px;
  width: 100%;
  padding: 15px;
  background: #cbbaba;
  border: none;
  border-radius: 6px;
  font-size: 16px;
  cursor: pointer;
}


</style>

</head>
<body>


<!-- MAIN CONTENT -->
<div class="container">

  <!-- LEFT -->
  <div class="card">
    <h2>Billing Information</h2>

    <div class="form-row full">

    <button type="button" class="change-address-btn" onclick="openAddressModal()">
      Change address
    </button>

    <div id="addressModal" class="address-modal">
  <div class="modal-content">
    <h3>Select Address</h3>

<div class="address-list">
  <% allAddress.forEach((addr, index) => { %>
    <label class="address-option">
      <input
        type="radio"
        name="addressSelect"
        value="<%= index %>"
        <%= addr.isDefault ? "checked" : "" %>
      />
      <div class="address-text">
        <strong><%= addr.name %></strong>
        <p>
          <%= addr.house %>, <%= addr.streetName %><br>
          <%= addr.city %>, <%= addr.state %> – <%= addr.pincode %>
        </p>
      </div>
    </label>
  <% }) %>
</div>

<div class="modal-actions">
  <button class="btn btn-primary" onclick="applySelectedAddress()">
    Use this address
  </button>
  <button class="btn btn-secondary" onclick="closeAddressModal()">
    Cancel
  </button>
</div>

  </div>
</div>
  </div>

    <div class="form-row">
      <div>
        <label>Name</label>
        <input id="name" type="text">
      </div>
      <div>
      <label>Region / State</label>
      <select id="state">
        <option value="">Select...</option>
        <option value="Kerala">Kerala</option>
        <option value="Tamil Nadu">Tamil Nadu</option>
        <option value="Karnataka">Karnataka</option>
      </select>
</div>

    </div>

     <div class="form-row">
     <div>
        <label>Address</label>
        <input id="ADDRESS" type="text">
        </div>
        <div>
          <label>Street name</label>
          <input id="streetName" type="text">
        </div>
      
      </div>

    <div class="form-row">
      <div>
      <label>City</label>
      <select id="city">
        <option value="">Select...</option>
        <option value="Ernakulam">Ernakulam</option>
        <option value="Trivandrum">Trivandrum</option>
        <option value="Bangalore">Bangalore</option>
      </select>
    </div>
      <div>
        <label>PIN Code</label>
        <input id="pincode" type="text">
      </div>
    </div>

    <div class="form-row">
      <div>
        <label>Email</label>
        <input id="email" type="email">
      </div>
      <div>
        <label>Phone Number</label>
        <input id="phone" type="text">
      </div>
    </div>

<div class="form-row full">
  <label class="default-address-row">
    <input id="defaultAddress" type="checkbox" name="defaultAddress" <%= defaultAddress ? "checked" : "" %> 
    <span>Default address</span>
  </label>
</div>


    <div class="payment">
      <h3>Payment Option</h3>
      <div class="payment-options">
        <div class="payment-box">
          💵<br>Cash on Delivery<br>
          <input type="radio" name="pay">
        </div>
        <div class="payment-box">
          ⚡<br>Razorpay<br>
          <input type="radio" name="pay">
        </div>
        <div class="payment-box">
          💳<br>My Wallet<br>
          <input type="radio" name="pay">
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="summary">
    <h3>Order Summary</h3>

<% cartItems.forEach(item => { %>
  <div class="product">
    <img src="<%= item.productId.images[0].url %>" alt="">
    <div>
      <%= item.productId.name %><br>
      <strong>₹<%= item.originalPrice %></strong> × <%= item.quantity %>
    </div>
  </div>
<% }) %>


    <div class="summary-row">
      <span>Sub-total</span><span>₹<%=subTotal%></span>
    </div>
    <div class="summary-row">
      <span>Shipping</span><span>Free</span>
    </div>
    <div class="summary-row">
      <span>Discount</span><span>-₹<%=discount%></span>
    </div>

    <div class="summary-total">
      ₹<%=total%>
    </div>

    <button class="place-order" onclick="handlePlaceOrder()">
      Place Order
    </button>

  </div>

</div>


<script>

  function showError(message) {
    Toastify({
      text: message,
      duration: 3000,
      gravity: "bottom",
      position: "center",
      close: true,
      style: {
        background: "linear-gradient(to right, #dc2626, #ef4444)"
      }
    }).showToast();
  }

  function showSuccess(message) {
    Toastify({
      text: message,
      duration: 3000,
      gravity: "bottom",
      position: "center",
      close: true,
      style: {
        background: "linear-gradient(to right, #16a34a, #22c55e)"
      }
    }).showToast();
  }

  // ===== DATA FROM BACKEND =====
  const defaultAddressDoc = <%- JSON.stringify(defaultAddress || null) %>;
  const addresses = <%- JSON.stringify(allAddress || []) %>;

  const checkbox = document.getElementById("defaultAddress");

  // ===== FORM FIELDS =====
  const fields = {
    name: document.querySelector("#name"),
    state: document.querySelector("#state"),
    city: document.querySelector("#city"),
    streetName: document.querySelector("#streetName"),
    address: document.querySelector("#ADDRESS"),
    email: document.querySelector("#email"),
    phone: document.querySelector("#phone"),
    pincode: document.querySelector("#pincode")
  };

  // ===== NORMALIZE DEFAULT ADDRESS =====
  const defaultAddr =
    defaultAddressDoc &&
    Array.isArray(defaultAddressDoc.address) &&
    defaultAddressDoc.address.length
      ? defaultAddressDoc.address[0]
      : null;

  // ===== HELPERS =====
  function setAddress(addr) {
    if (!addr) return;

    fields.name.value = addr.name || "";
    fields.state.value = addr.state || "";
    fields.city.value = addr.city || "";
    fields.streetName.value = addr.streetName || "";
    fields.address.value = addr.house || "";
    fields.email.value = addr.email || "";
    fields.phone.value = addr.phone || "";
    fields.pincode.value = addr.pincode || "";
  }

  function clearAddress() {
    Object.values(fields).forEach(field => field.value = "");
  }

  // ===== DEFAULT CHECKBOX BEHAVIOR =====
  if (checkbox && checkbox.checked && defaultAddr) {
    setAddress(defaultAddr);
  }

  checkbox.addEventListener("change", function () {
    if (this.checked) {
      setAddress(defaultAddr);
    } else {
      clearAddress();
    }
  });

  // ===== ADDRESS MODAL =====
  function openAddressModal() {
    document.getElementById("addressModal").style.display = "flex";
  }

  function closeAddressModal() {
    document.getElementById("addressModal").style.display = "none";
  }

  function applySelectedAddress() {
    const selected = document.querySelector(
      'input[name="addressSelect"]:checked'
    );
    if (!selected) return;

    const addr = addresses[selected.value];
    setAddress(addr);

    // Using another address → not default
    checkbox.checked = false;

    closeAddressModal();
  }
  //VALIDATION

  function isValidEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  function isValidPhone(phone) {
    return /^[6-9]\d{9}$/.test(phone);
  }

  function isValidPincode(pin) {
    return /^\d{6}$/.test(pin);
  }


  function validateCheckout() {
    if (!fields.name.value.trim()) {
      showError("Please enter your name");
      return false;
    }

    if (!fields.state.value) {
      showError("Please select a state");
      return false;
    }

    if (!fields.city.value) {
      showError("Please select a city");
      return false;
    }

    if (!fields.address.value.trim()) {
      showError("Please enter address");
      return false;
    }

    if (!fields.streetName.value.trim()) {
      showError("Please enter street name");
      return false;
    }

    if (!isValidPincode(fields.pincode.value)) {
      showError("Please enter a valid 6-digit PIN code");
      return false;
    }

    if (!isValidEmail(fields.email.value)) {
      showError("Please enter a valid email address");
      return false;
    }

    if (!isValidPhone(fields.phone.value)) {
      showError("Please enter a valid 10-digit phone number");
      return false;
    }

    const paymentSelected = document.querySelector('input[name="pay"]:checked');
    if (!paymentSelected) {
      showError("Please select a payment option");
      return false;
    }

    return true;
  }

  async function handlePlaceOrder() {
    if (!validateCheckout()) return;

      const res = await fetch("/user/place-order", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        paymentMethod: "COD"
      })
    });

    const data = await res.json();

    if (!res.ok) {
      showToast(data.message, "error");
      return;
    }
    if(res.ok && data.success){
      const orderId = data.orderId
      console.log(orderId)
      window.location.href = `/user/order/${orderId}`
    }
    
  }


</script>



<%- include("../../views/partials/user/footer") %>


