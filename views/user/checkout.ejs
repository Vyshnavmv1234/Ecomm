<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Checkout</title>

<style>
* {
  box-sizing: border-box;
  font-family: Arial, sans-serif;
}

body {
  margin: 0;
  background: #f7f7f7;
  color: #222;
}

/* ---------- HEADER ---------- */
.header {
  background: #fff;
  padding: 15px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid #ddd;
}

.logo {
  font-size: 28px;
  font-weight: bold;
}

.search {
  flex: 1;
  margin: 0 40px;
}

.search input {
  width: 100%;
  padding: 10px 15px;
  border-radius: 20px;
  border: 1px solid #ccc;
}

/* ---------- MAIN ---------- */
.container {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 30px;
  padding: 40px;
}

/* ---------- FORM ---------- */
.card {
  background: #fff;
  padding: 30px;
  border-radius: 6px;
}

.card h2 {
  margin-bottom: 20px;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 15px;
}

.form-row.full {
  grid-template-columns: 1fr;
}

input, select {
  width: 100%;
  padding: 12px;
  border: 1px solid #ddd;
  border-radius: 4px;
}

label {
  font-size: 14px;
  margin-bottom: 6px;
  display: block;
}

.checkbox {
  margin-top: 15px;
}

/* ---------- PAYMENT ---------- */
.payment {
  margin-top: 30px;
}

.payment-options {
  display: flex;
  justify-content: space-between;
  margin-top: 20px;
}

.payment-box {
  flex: 1;
  text-align: center;
  padding: 20px;
  border-right: 1px solid #ddd;
}

.payment-box:last-child {
  border-right: none;
}

/* ---------- ORDER SUMMARY ---------- */
.summary {
  background: #fff;
  padding: 25px;
  border-radius: 6px;
}

.summary h3 {
  margin-bottom: 20px;
}

.product {
  display: flex;
  gap: 15px;
  margin-bottom: 15px;
}

.product img {
  width: 60px;
  height: 60px;
  object-fit: cover;
  border-radius: 4px;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  margin: 10px 0;
  font-size: 14px;
}

.summary-total {
  font-weight: bold;
  font-size: 18px;
  margin-top: 15px;
}

.place-order {
  margin-top: 20px;
  width: 100%;
  padding: 15px;
  background: #cbbaba;
  border: none;
  border-radius: 6px;
  font-size: 16px;
  cursor: pointer;
}

/* ---------- FOOTER ---------- */
.footer {
  background: #fff;
  padding: 40px;
  display: flex;
  justify-content: space-between;
  margin-top: 40px;
  border-top: 1px solid #ddd;
}

.footer h4 {
  margin-bottom: 10px;
}
</style>

</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="logo">WestLane</div>
  <div class="search">
    <input type="text" placeholder="What are you looking for?">
  </div>
  <div>❤️ 🛒 ☰ 👤 Vyshnav</div>
</div>

<!-- MAIN CONTENT -->
<div class="container">

  <!-- LEFT -->
  <div class="card">
    <h2>Edit Billing Information</h2>

    <div class="form-row">
      <div>
        <label>First Name</label>
        <input type="text">
      </div>
      <div>
        <label>Last Name</label>
        <input type="text">
      </div>
    </div>

    <div class="form-row full">
      <div>
        <label>Company Name (Optional)</label>
        <input type="text">
      </div>
    </div>

    <div class="form-row full">
      <div>
        <label>Address</label>
        <input type="text">
      </div>
    </div>

    <div class="form-row">
      <div>
        <label>Country</label>
        <select><option>Select...</option></select>
      </div>
      <div>
        <label>Region / State</label>
        <select><option>Select...</option></select>
      </div>
    </div>

    <div class="form-row">
      <div>
        <label>City</label>
        <select><option>Select...</option></select>
      </div>
      <div>
        <label>PIN Code</label>
        <input type="text">
      </div>
    </div>

    <div class="form-row">
      <div>
        <label>Email</label>
        <input type="email">
      </div>
      <div>
        <label>Phone Number</label>
        <input type="text">
      </div>
    </div>

    <div class="checkbox">
      <input type="checkbox"> Ship into default address
    </div>

    <div class="payment">
      <h3>Payment Option</h3>
      <div class="payment-options">
        <div class="payment-box">
          💵<br>Cash on Delivery<br>
          <input type="radio" name="pay">
        </div>
        <div class="payment-box">
          ⚡<br>Razorpay<br>
          <input type="radio" name="pay">
        </div>
        <div class="payment-box">
          💳<br>My Wallet<br>
          <input type="radio" name="pay">
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="summary">
    <h3>Order Summary</h3>

    <div class="product">
      <img src="https://via.placeholder.com/60">
      <div>
        Samsung Galaxy book 4 pro<br>
        <strong>₹69000</strong>
      </div>
    </div>

    <div class="product">
      <img src="https://via.placeholder.com/60">
      <div>
        Samsung Galaxy S25 Ultra<br>
        <strong>₹92999</strong>
      </div>
    </div>

    <div class="summary-row">
      <span>Sub-total</span><span>₹161999</span>
    </div>
    <div class="summary-row">
      <span>Shipping</span><span>Free</span>
    </div>
    <div class="summary-row">
      <span>Discount</span><span>-₹2400</span>
    </div>
    <div class="summary-row">
      <span>Tax</span><span>₹11000</span>
    </div>

    <div class="summary-total">
      Total ₹163,999 INR
    </div>

    <button class="place-order">Place Order</button>
  </div>

</div>

<!-- FOOTER -->
<div class="footer">
  <div>
    <h4>WestLane</h4>
    Facebook · Instagram · YouTube · Twitter
  </div>
  <div>
    <h4>Shop</h4>
    Woman<br>Man<br>Kids<br>Home
  </div>
  <div>
    <h4>Sites & Stores</h4>
    About Us<br>Contact Us<br>Terms & Conditions
  </div>
</div>

</body>
</html>
