<%- include("../../views/partials/user/header") %>

<style>
  /* ===== 404 ERROR PAGE ===== */

  .error-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding: 60px 20px;
    user-select: none;
  }

  /* Large "404" display */
  .error-code {
    font-family: 'Playfair Display', serif;
    font-size: clamp(100px, 20vw, 180px);
    font-weight: 400;
    color: #111;
    line-height: 1;
    letter-spacing: -4px;
    margin-bottom: 8px;
  }

  /* Thin decorative divider */
  .error-divider {
    width: 60px;
    height: 1px;
    background: #ccc;
    margin: 0 auto 28px;
  }

  /* "PAGE NOT FOUND" label */
  .error-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 20px;
  }

  /* Subtitle message */
  .error-message {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: #666;
    line-height: 1.7;
    max-width: 400px;
    margin: 0 auto 40px;
  }

  /* Home button */
  .home-btn {
    display: inline-block;
    padding: 14px 36px;
    border: 1px solid #111;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #111;
    background: transparent;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease;
  }

  .home-btn:hover {
    background: #111;
    color: #fff;
  }

  /* Responsive */
  @media (max-width: 480px) {
    .error-code {
      letter-spacing: -2px;
    }

    .error-message {
      font-size: 14px;
    }

    .home-btn {
      padding: 12px 28px;
    }
  }
</style>

<main>
  <div class="error-wrapper">
    <div class="error-code">404</div>
    <div class="error-divider"></div>
    <p class="error-label">Page Not Found</p>
    <p class="error-message">
      We couldn't find the page you were looking for.<br>
      It may have been moved, deleted, or never existed.
    </p>
    <a href="/user/homepage" class="home-btn">← Back to Home</a>
  </div>
</main>

<%- include("../../views/partials/user/footer") %>
