<%- include("../../views/partials/user/header") %>

<% activePage = "orders"; %>

<style>
  /* ===== ORDER HISTORY SPECIFIC ===== */
  .order-card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 18px rgba(0,0,0,0.06);
    overflow: hidden;
  }

  .order-header {
    padding: 16px 20px;
    font-size: 13px;
    font-weight: 600;
    background: #f6f6f6;
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr 1.5fr 1fr;
    color: #666;
  }

  .order-row {
    padding: 18px 20px;
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr 1.5fr 1fr;
    align-items: center;
    border-bottom: 1px solid #eee;
    font-size: 14px;
  }

  .order-row:last-child {
    border-bottom: none;
  }

  .status {
    font-weight: 600;
    font-size: 13px;
  }

  .status.progress { color: #ff7a00; }
  .status.delivered { color: #00a651; }

  .action a {
    text-decoration: none;
    color: #2563eb;
    font-weight: 500;
  }

  /* ===== PAGINATION ===== */
  .pagination {
    display: flex;
    justify-content: center;
    gap: 10px;
    padding: 25px 0;
  }

  .page-btn {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid #c8bcbc;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    color: #555;
    cursor: pointer;
    background: #fff;
    text-decoration: none;
  }

  .page-btn.active {
    background: #cfc0bc;
    color: #fff;
    border-color: #cfc0bc;
    font-weight: 600;
  }

  .page-btn:hover {
    background: #eee;
  }

  /* Responsive: stack order grid on small screens */
  @media (max-width: 640px) {
    .order-header { display: none; }
    .order-row {
      grid-template-columns: 1fr 1fr;
      gap: 6px;
      font-size: 13px;
    }
  }
</style>

<!-- MAIN LAYOUT -->
<div class="user-layout">

  <%- include("../../views/partials/user/sidebar") %>

  <!-- CONTENT -->
  <div class="user-content">
    <div class="order-card">

      <div class="order-header">
        <div>PRODUCT NAME</div>
        <div>STATUS</div>
        <div>DATE</div>
        <div>TOTAL</div>
        <div>ACTION</div>
      </div>

      <%if(orders){%>
        <% orders.forEach(order => { %>
      <div class="order-row">
        <div>
          <%= order.orderItems[0]?.product?.name || "Product" %>
        </div>

        <div class="status <%= order.status === 'delivered' ? 'delivered' : 'progress' %>">
          <%= order.status%>
        </div>

        <div>
          <%= order.createdAt.toLocaleDateString() %>
        </div>

        <div>
          ₹<%= order.orderSummary.total %> (<%= order.orderItems.length %> Items)
        </div>

        <div class="action">
          <a href="/orders/detail/<%= order._id %>">View Details →</a>
        </div>
      </div>
      <% }) %>
      <%}else{%>
        <p style="padding:20px;">No orders found</p>
      <%}%>

      <!-- PAGINATION -->
      <div class="pagination">
  <% if (currentPage > 1) { %>
    <a href="?page=<%= currentPage - 1 %>" class="page-btn arrow">←</a>
  <% } %>

  <% for (let i = 1; i <= totalPages; i++) { %>
    <a
      href="?page=<%= i %>"
      class="page-btn <%= currentPage === i ? 'active' : '' %>">
      <%= i %>
    </a>
  <% } %>

  <% if (currentPage < totalPages) { %>
    <a href="?page=<%= currentPage + 1 %>" class="page-btn arrow">→</a>
  <% } %>
</div>

    </div>
  </div>

</div>

<%- include("../../views/partials/user/footer") %>
