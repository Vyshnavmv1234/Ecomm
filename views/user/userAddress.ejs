<%- include("../../views/partials/user/header") %>

<% activePage = "address"; %>

<style>
/* ADDRESS CARD */
.address-card{
  padding:20px;
  border-radius:8px;
  border:2px solid transparent;
  cursor:pointer;
  transition:0.25s;
  margin-bottom:15px;
  background:#fff;
}

.address-card:hover{
  border-color:#8c9dc2;
}

/* DEFAULT ADDRESS */
.active-address{
  border:2px solid #8c9dc2;
  background:#eff6ff;
}

/* BUTTONS */
.edit-btn{
  padding:8px 18px;
  border:1px solid #2fbc47;
  color:#68b432;
  border-radius:6px;
  text-decoration:none;
}

.delete-btn{
  padding:8px 18px;
  border:1px solid red;
  color:red;
  border-radius:6px;
  cursor:pointer;
  background:none;
}
</style>

<!-- ================= MAIN ================= -->
<div class="user-layout">

  <!-- SIDEBAR -->
  <%- include("../../views/partials/user/sidebar") %>

  <!-- CONTENT -->
  <div class="user-content">
    <div style="background:#fff; border-radius:8px; padding:25px; border:1px solid #e5e5e5;">

      <h4 style="margin-bottom:20px;">ADDRESS</h4>

      <% if(userAddress && userAddress.address.length > 0){ %>

        <% userAddress.address.forEach(address => { %>

        <!-- ADDRESS CARD -->
        <div
          class="address-card <%= address.isDefault ? 'active-address' : '' %>"
          onclick="setDefaultAddress('<%= address._id %>', this)"
        >

          <p><%= address.name %></p>
          <p><%= address.house %></p>
          <p><%= address.streetName %></p>
          <p><%= address.city %></p>
          <p><%= address.state %></p>
          <p><%= address.pincode %></p>
          <p><%= address.phone %></p>

          <!-- ACTION BUTTONS -->
          <div style="display:flex; gap:12px; margin-top:10px;">

            <a href="/user/edit-address?id=<%= address._id %>"
               onclick="event.stopPropagation()"
               class="edit-btn">
              Edit address
            </a>

            <button
              onclick="event.stopPropagation();
                       deleteAddress('<%= address._id %>')"
              class="delete-btn">
              Delete address
            </button>

          </div>

        </div>

        <hr>

        <% }) %>

      <% } %>

      <!-- ADD ADDRESS -->
      <div style="display:flex; justify-content:center; margin-top:20px;">
        <a href="/user/add-address"
           style="padding:8px 18px;
                  border:1px solid #2bb0c0;
                  color:#2bb0c0;
                  border-radius:6px;
                  text-decoration:none;">
          Add address
        </a>
      </div>

    </div>
  </div>

</div>

<!-- SweetAlert -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>

/* ===============================
   TOAST
================================*/
function showToast(msg,type="success"){
  Toastify({
    text:msg,
    duration:2500,
    gravity:"bottom",
    position:"center",
    style:{
      background:
        type==="success"
        ?"linear-gradient(to right,#16a34a,#22c55e)"
        :"linear-gradient(to right,#dc2626,#ef4444)"
    }
  }).showToast();
}


/* ===============================
   SET DEFAULT ADDRESS
================================*/
async function setDefaultAddress(id,el){

try{

  const res = await fetch(
    "/user/address/set-default",
    {
      method:"PATCH",
      headers:{
        "Content-Type":"application/json"
      },
      body:JSON.stringify({addressId:id})
    }
  );

  const data = await res.json();

  if(!data.success){
    showToast("Failed to update","error");
    return;
  }

  document
    .querySelectorAll(".address-card")
    .forEach(card =>
      card.classList.remove("active-address")
    );

  el.classList.add("active-address");

  showToast("Default address selected");

}catch(err){
  console.error(err);
  showToast("Server error","error");
}

}


/* ===============================
   DELETE ADDRESS
================================*/
async function deleteAddress(id){

const result = await Swal.fire({
  title:"Delete Address?",
  text:"This address will be removed",
  icon:"warning",
  showCancelButton:true,
  confirmButtonColor:"#dc2626",
  confirmButtonText:"Delete"
});

if(!result.isConfirmed) return;

window.location.href =
  `/user/delete-address?id=${id}`;
}

</script>

<%- include("../../views/partials/user/footer") %>