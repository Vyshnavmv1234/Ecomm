<%- include("../../views/partials/user/header") %>

<style>
  body {
    background: #f6f6f6;
  }

  .order-success-section {
    width: 100%;
    padding: 80px 20px 120px;
    display: flex;
    justify-content: center;
  }

  .order-success-card {
    background: #fff;
    width: 100%;
    max-width: 900px;
    padding: 70px 60px;
    border-radius: 16px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.12);
    text-align: center;
  }

  .success-icon {
    width: 140px;
    height: 140px;
    background: #418758;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0 auto 30px;
  }

  .success-icon span {
    color: #fff;
    font-size: 56px;
    font-weight: bold;
  }

  .order-success-card h1 {
    font-size: 34px;
    color: #222;
    margin-bottom: 14px;
  }

  .order-success-card p {
    font-size: 17px;
    color: #666;
    max-width: 520px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .order-actions {
    display: flex;
    justify-content: center;
    gap: 20px;
  }

  .order-actions a {
    text-decoration: none;
    padding: 16px 34px;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 500;
    transition: 0.3s ease;
  }

  .btn-view {
    border: 1px solid #ccc;
    color: #333;
    background: #fff;
  }

  .btn-view:hover {
    background: #f1f1f1;
  }

  .btn-shop {
    background: #c5b2b2;
    color: #fff;
  }

  .btn-shop:hover {
    background: #418758;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .order-success-card {
      padding: 50px 30px;
    }

    .order-actions {
      flex-direction: column;
    }

    .order-actions a {
      width: 100%;
      text-align: center;
    }
  }
</style>

<section class="order-success-section">
  <div class="order-success-card">
    <div class="success-icon">
      <span>✓</span>
    </div>

    <h1>Thank you for your order!</h1>
    <p>
      Your order has been placed successfully.  
      We’ll send you a notification once your items are shipped.
    </p>
    <p>
      ORDER ID - <%=orderID.orderId%>
    </p>

    <div class="order-actions">
      <a href="/user/orderDetail/<%=orderId%>" class="btn-view">View Order</a>
      <a href="/user/productList" class="btn-shop">Continue Shopping</a>
    </div>
  </div>
</section>


<%- include("../../views/partials/user/footer") %>
