</div>
<link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
    />

    <!-- Toastify JS -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

<script id="product-data" type="application/json">
  <%- JSON.stringify(productData) %>
</script>

<script>
  const priceEl = document.getElementById("productPrice")
  const stockEl = document.getElementById("stockStatus")
  const addError = document.getElementById("addError")  

  function showToast(message, type = "success") {
        Toastify({
        text: message,
        duration: 3000,
        gravity: "bottom",       
        position: "center",    
        close: true,
        stopOnFocus: true,
        style: {
          background:
            type === "success"
              ? "linear-gradient(to right, #16a34a, #22c55e)"
              : "linear-gradient(to right, #dc2626, #ef4444)",
        }
      }).showToast();
    }

  /* ===== READ PRODUCT DATA SAFELY ===== */
  const PRODUCT = JSON.parse(
    document.getElementById("product-data").textContent
  );

  /* ===== IMAGE GALLERY ===== */

  function changeImage(imageUrl, el) {
    document.getElementById("mainProductImage").src = imageUrl;

    document.querySelectorAll(".thumbnail").forEach(t => {
      t.classList.remove("active");
    });

    el.classList.add("active");
  }

  /* ===== IMAGE ZOOM ===== */

  const zoomImage = document.getElementById("mainProductImage");

  zoomImage.addEventListener("mousemove", function (e) {
    const rect = this.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width) * 90;
    const y = ((e.clientY - rect.top) / rect.height) * 90;

    this.style.transformOrigin = `${x}% ${y}%`;
    this.style.transform = "scale(1.8)";
  });

  zoomImage.addEventListener("mouseleave", function () {
    this.style.transform = "scale(1)";
  });

let selectedVariantId = null
let selectedSize = null
let selectedPrice = null

document.addEventListener("DOMContentLoaded", () => {
  const firstOption = document.querySelector(".size-option")
  if (firstOption) {
    selectSize(firstOption, firstOption.getAttribute("onclick").match(/'([^']+)'/)[1])
  }
})

function selectSize(el, id) {

  const originalPriceEl =
    document.getElementById("originalPrice");

  const stock = Number(el.dataset.stock);

  const finalPrice =
    Number(el.dataset.price);  

  const originalPrice =
    Number(el.dataset.originalprice);

  selectedVariantId = id;
  selectedSize = el.dataset.size;
  selectedPrice = finalPrice;

  /* PRICE UPDATE */
  if(priceEl){
    priceEl.innerText = "₹" + finalPrice;
  }

  /* ORIGINAL PRICE */
  if(originalPriceEl){
    originalPriceEl.innerText =
      "₹" + originalPrice;

    if(finalPrice === originalPrice){
      originalPriceEl.style.display="none";
    }else{
      originalPriceEl.style.display="inline";
    }
  }

  /* STOCK */
  if (stock > 0) {
    stockEl.innerText = "IN STOCK";
    stockEl.className = "in-stock";
  } else {
    stockEl.innerText = "OUT OF STOCK";
    stockEl.className = "out-stock";
  }

  document
    .querySelectorAll(".size-option")
    .forEach(s => s.classList.remove("active"));

  el.classList.add("active");

  addError.innerText = "";
}

  /* ===== ADD TO CART ===== */

 async function eFun(id){

  if (!selectedVariantId) {

      addError.innerText = "Please select a size"
      addError.style.color = "red"
      return
    }

    const submitBtn =
    document.getElementById("Basket");

  if (submitBtn.disabled) return false;

  submitBtn.disabled = true;
  submitBtn.textContent = "Adding...";

    const res = await fetch("/cart",{
      
      method: "POST",
      headers:{
        "Content-Type":"application/json"
      },
      body: JSON.stringify({productId:id,variantId:selectedVariantId})
    })

    const data = await res.json()

    if (res.status === 401) {
      showToast(data.message || "Please login", "error")

      setTimeout(() => {
        window.location.href = "/login"
      }, 1200)

      return
    }
    if (res.status === 500) {
      showToast(data.message || "Please login", "error")

      setTimeout(() => {
        window.location.href = "/404"
      }, 1200)

      return
    }
    if (res.status === 403) {
      showToast(data.message || "Product is blocked by admin", "error")

      setTimeout(() => {
        window.location.href = "/shop"
      }, 1200)

      return
    }
    if (res.status === 404) {
      showToast(data.message, "error")
      return
    }
    if (res.status === 400) {
      showToast(data.message, "error")
      return
    }

    if(res.ok && data.success){
      showToast("Product added to cart successfully","success")

      setTimeout(()=>{
        window.location.href = "/cart"
      },800)
    }
    
  }
  
async function toggleWishlist(productId) {
  if (!selectedVariantId) {
    showToast("Please select a size", "error")
    return
  }

  const res = await fetch("/wishlist", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      productId,
      variantId: selectedVariantId
    })
  })

  const data = await res.json()

  if (!res.ok) {
    showToast(data.message || "Error", "error")
    return
  }

  const btn = document.querySelector(".wishlist-btn")

  if (data.action === "added") {
    btn.classList.add("active")
    btn.innerText = "♥"
    showToast("Added to wishlist", "success")
  } else {
    btn.classList.remove("active")
    btn.innerText = "♡"
    showToast("Removed from wishlist", "success")
  }
}



</script>


