<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>WestLane | Orders</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Global Styles -->
  <%- include("../../views/partials/admin/adminStyles") %>
  
  <style>
    /* Specific table/badge overrides for Orders */
    .badge-payment-online { background: rgba(67, 97, 238, 0.1); color: var(--primary); }
    .badge-payment-cod { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
    
    .search-container { max-width: 350px; }
    /* Fix for overlapping elements blocking clicks */
    .content { position: relative; z-index: 1; }
    .card { position: relative; z-index: 2; }
    .btn { position: relative; z-index: 5; }
  </style>
</head>

<body>
  
<div class="layout">
  <!-- SIDEBAR -->
  <%- include("../../views/partials/admin/sidebar") %>

  <!-- CONTENT -->
  <div class="content">
    <!-- HEADER -->
    <%- include("../../views/partials/admin/header") %>

    <!-- MAIN -->
    <main class="main">
      
      <!-- PAGE HEADER -->
      <div class="d-flex justify-between align-center mb-4">
        <div>
          <h2>Orders Management</h2>
          <nav class="text-muted d-flex gap-2">
            <a href="/admin/adminDashboard" style="color: var(--primary); text-decoration: none;">Dashboard</a>
            <span>/</span>
            <span>Orders</span>
          </nav>
        </div>
        <button class="btn btn-primary" onclick="openReturnModal()">
          <i class="fas fa-undo"></i> Return Requests
        </button>
      </div>

      <!-- SEARCH & FILTERS -->
      <div class="card">
        <div class="d-flex justify-between align-center flex-wrap gap-3">
          <form method="get" action="/admin/order" class="search-container w-full">
            <div class="d-flex gap-2">
              <input name="search" type="text" placeholder="Search by Order ID or Customer..." value="<%= search || '' %>" />
              <button type="submit" class="btn btn-outline">
                <i class="fas fa-search"></i>
              </button>
            </div>
            <input type="hidden" name="status" value="<%= selectedStatus || '' %>">
          </form>

          <div class="filter-bar mb-0">
            <a href="/admin/order?search=<%= search %>" class="filter-btn <%= !selectedStatus ? 'active' : '' %>">All</a>
            <a href="/admin/order?status=pending&search=<%= search %>" class="filter-btn <%= selectedStatus === 'pending' ? 'active' : '' %>">Pending</a>
            <a href="/admin/order?status=processing&search=<%= search %>" class="filter-btn <%= selectedStatus === 'processing' ? 'active' : '' %>">Processing</a>
            <a href="/admin/order?status=shipped&search=<%= search %>" class="filter-btn <%= selectedStatus === 'shipped' ? 'active' : '' %>">Shipped</a>
            <a href="/admin/order?status=delivered&search=<%= search %>" class="filter-btn <%= selectedStatus === 'delivered' ? 'active' : '' %>">Delivered</a>
            <a href="/admin/order?status=cancelled&search=<%= search %>" class="filter-btn <%= selectedStatus === 'cancelled' ? 'active' : '' %>">Cancelled</a>
          </div>
        </div>
      </div>

      <!-- ORDERS TABLE -->
      <div class="card">
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Products</th>
                <th>Date</th>
                <th>Customer</th>
                <th>Total</th>
                <th>Payment</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (orders.length === 0) { %>
                <tr>
                  <td colspan="8" style="text-align:center; padding:40px;">
                    <i class="fas fa-box-open" style="font-size: 40px; color: var(--gray-300); margin-bottom: 15px; display: block;"></i>
                    <p class="text-muted">No orders found.</p>
                  </td>
                </tr>
              <% } %>

              <% orders.forEach(order => { %>
                <tr>
                  <td style="font-weight: 600;">#<%= order.orderId %></td>
                  <td>
                    <div style="font-size: 0.8rem;">
                      <% order.orderItems.forEach(item => { %>
                        <div class="mb-1">
                          <span style="font-weight: 500;"><%= item.product ? item.product.name : "Product deleted" %></span>
                          <span class="text-muted">× <%= item.quantity %></span>
                          <% if (item.status === "cancelled") { %>
                            <span class="badge badge-danger btn-sm">Cancelled</span>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>
                  </td>
                  <td class="text-muted"><%= order.createdAt.toDateString() %></td>
                  <td style="font-weight: 500;"><%= order.shipping_address.name %></td>
                  <td style="font-weight: 700; color: var(--dark);">₹<%= order.orderSummary.total.toLocaleString() %></td>
                  <td>
                    <span class="badge <%= order.paymentMethod.toLowerCase() === 'cod' ? 'badge-warning' : 'badge-primary' %>">
                      <%= order.paymentMethod %>
                    </span>
                  </td>
                  <td>
                    <% 
                      let statusClass = "badge-info";
                      if(order.status === 'Delivered') statusClass = "badge-success";
                      if(order.status === 'Cancelled') statusClass = "badge-danger";
                      if(order.status === 'Shipped') statusClass = "badge-primary";
                      if(order.status === 'Pending') statusClass = "badge-warning";
                    %>
                    <span class="badge <%= statusClass %>">
                      <%= order.status %>
                    </span>
                  </td>
                  <td>
                    <a href="/admin/editOrder/<%= order._id %>" class="btn btn-outline btn-sm" title="Edit Order">
                      <i class="fas fa-edit"></i> Edit
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- PAGINATION -->
        <% if (totalPages > 1) { %>
          <div class="pagination">
            <% if (currentPage > 1) { %>
              <a class="page-link" href="?page=<%= currentPage - 1 %>&status=<%= selectedStatus %>&search=<%= search %>">
                <i class="fas fa-chevron-left"></i>
              </a>
            <% } %>

            <% for (let i = 1; i <= totalPages; i++) { %>
              <a class="page-link <%= currentPage === i ? 'active' : '' %>" href="?page=<%= i %>&status=<%= selectedStatus %>&search=<%= search %>">
                <%= i %>
              </a>
            <% } %>

            <% if (currentPage < totalPages) { %>
              <a class="page-link" href="?page=<%= currentPage + 1 %>&status=<%= selectedStatus %>&search=<%= search %>">
                <i class="fas fa-chevron-right"></i>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </main>
  </div>
</div>

<!-- RETURN REQUESTS MODAL -->
<div id="returnModal" class="modal">
  <div class="modal-content" style="max-width: 900px;">
    <span class="close" onclick="closeReturnModal()">&times;</span>
    <div class="modal-header mb-4">
      <h3>Customer Return Requests</h3>
      <p class="text-muted" style="font-size: 0.875rem;">Manage and review item return requests from customers.</p>
    </div>
    
    <% if (returnOrders.length === 0) { %>
      <div style="text-align: center; padding: 60px 20px;">
        <i class="fas fa-check-circle fa-3x" style="color: var(--success); opacity: 0.2; margin-bottom: 20px; display: block;"></i>
        <h4 style="color: var(--gray-600);">No requests pending</h4>
        <p class="text-muted">All customer returns have been processed.</p>
      </div>
    <% } else { %>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Order Ref</th>
              <th>Customer</th>
              <th>Reason for Return</th>
              <th style="min-width: 180px; text-align: right;">Action</th>
            </tr>
          </thead>
          <tbody>
            <% returnOrders.forEach(order => { %>
              <% if (order.returnStatus === "requested") { %>
                <tr style="background-color: var(--gray-50);">
                  <td style="font-weight: 700; color: var(--primary);">#<%= order.orderId || order._id.toString().slice(-6).toUpperCase() %></td>
                  <td style="font-weight: 500;"><%= order.userId?.name %></td>
                  <td>
                    <span class="badge badge-info mb-1">Full Order Return</span>
                    <div class="text-muted" style="font-size: 13px;"><%= order.returnReason %></div>
                  </td>
                  <td>
                    <div class="d-flex gap-2 justify-end">
                      <form action="/admin/handle-return" method="POST" style="display:contents;">
                        <input type="hidden" name="orderId" value="<%= order._id %>">
                        <button class="btn btn-success btn-sm" name="action" value="approve">Approve</button>
                        <button class="btn btn-danger btn-sm" name="action" value="reject">Reject</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% } %>
              
              <% order.orderItems.forEach(item => { %>
                <% if (item.returnStatus === "requested") { %>
                  <tr>
                    <td style="font-weight: 600;">#<%= order.orderId || order._id.toString().slice(-6).toUpperCase() %></td>
                    <td style="font-weight: 500;"><%= order.userId?.name %></td>
                    <td>
                      <div class="d-flex align-center gap-2 mb-1">
                        <span class="badge badge-warning">Specific Item</span>
                        <strong style="font-size: 13px;"><%= item.product?.name %></strong>
                      </div>
                      <div class="text-muted" style="font-size: 13px;"><%= item.returnReason %></div>
                    </td>
                    <td>
                      <div class="d-flex gap-2 justify-end">
                        <form action="/admin/handle-return" method="POST" style="display:contents;">
                          <input type="hidden" name="orderId" value="<%= order._id %>">
                          <input type="hidden" name="itemId" value="<%= item._id %>">
                          <button class="btn btn-success btn-sm" name="action" value="approve">Approve</button>
                          <button class="btn btn-danger btn-sm" name="action" value="reject">Reject</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% } %>
              <% }) %>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <div class="mt-4 pt-3 border-top d-flex justify-end">
      <button class="btn btn-outline" onclick="closeReturnModal()">Close Panel</button>
    </div>
  </div>
</div>

<script>
  function openReturnModal() {
    document.getElementById("returnModal").style.display = "flex";
  }

  function closeReturnModal() {
    document.getElementById("returnModal").style.display = "none";
  }

  window.onclick = function (e) {
    const modal = document.getElementById("returnModal");
    if (e.target === modal) closeReturnModal();
  };
</script>

</body>
</html>
