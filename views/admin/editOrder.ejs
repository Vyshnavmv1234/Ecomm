<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>WestLane | Order Details</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <%- include("../../views/partials/admin/adminStyles") %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  
  <style>
    .grid-order {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .order-item-table { width: 100%; border-collapse: collapse; }
    .order-item-table th, .order-item-table td { padding: 12px; border-bottom: 1px solid var(--gray-100); }
    .status-final { font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }

    @media (max-width: 1024px) {
      .grid-order { grid-template-columns: 1fr; }
    }
  </style>
</head>

<body>
  
<div class="layout">
  <!-- SIDEBAR -->
  <%- include("../../views/partials/admin/sidebar") %>

  <!-- CONTENT -->
  <div class="content">
    <!-- HEADER -->
    <%- include("../../views/partials/admin/header") %>

    <!-- MAIN -->
    <main class="main">
      <div class="d-flex justify-between align-center mb-4">
        <div>
          <h2>Order Details</h2>
          <nav class="text-muted d-flex gap-2">
            <a href="/admin/order" style="color: var(--primary); text-decoration: none;">Orders</a>
            <span>/</span>
            <span>#<%= order._id.toString().slice(-6).toUpperCase() %></span>
          </nav>
        </div>
      </div>

      <!-- Top Info Cards -->
      <div class="grid-order mb-4">
        <div class="card">
          <h4>Order Info</h4>
          <div class="d-flex justify-between mb-2">
            <span class="text-muted">Order ID</span>
            <span style="font-weight: 600;">#<%= order._id %></span>
          </div>
          <div class="d-flex justify-between mb-2">
            <span class="text-muted">Date</span>
            <span><%= order.createdAt.toDateString() %></span>
          </div>
          <div class="d-flex justify-between mb-2">
            <span class="text-muted">Payment</span>
            <span class="badge badge-info"><%= order.paymentMethod || "COD" %></span>
          </div>
          <div class="d-flex justify-between">
            <span class="text-muted">Status</span>
            <span class="badge badge-primary"><%= order.status %></span>
          </div>
        </div>

        <div class="card">
          <h4>Customer</h4>
          <div class="d-flex justify-between mb-2">
            <span class="text-muted">Name</span>
            <span style="font-weight: 600;"><%= order.shipping_address.name %></span>
          </div>
          <div class="d-flex justify-between mb-2">
            <span class="text-muted">Phone</span>
            <span><%= order.shipping_address.phone %></span>
          </div>
          <div class="d-flex justify-between">
            <span class="text-muted">City</span>
            <span><%= order.shipping_address.city %></span>
          </div>
        </div>

        <div class="card">
          <h4>Update Status</h4>
          <% const isFinal = ["delivered", "cancelled", "returned"].includes(order.status.toLowerCase()); %>
          <% if (isFinal) { %>
            <div class="text-center py-3">
              <span class="status-final <%= order.status.toLowerCase() === 'delivered' ? 'text-success' : 'text-danger' %>">
                <%= order.status %>
              </span>
              <p class="text-muted mt-2" style="font-size: 11px;">Final state reached.</p>
            </div>
          <% } else { %>
            <input type="hidden" id="orderId" value="<%= order._id %>">
            <div class="form-group mb-3">
              <select id="statusSelect">
                <option value="pending" <%= order.status.toLowerCase()==="pending"?"selected":"" %>>Pending</option>
                <option value="shipped" <%= order.status.toLowerCase()==="shipped"?"selected":"" %>>Shipped</option>
                <option value="out for delivery" <%= order.status.toLowerCase()==="out for delivery"?"selected":"" %>>Out for Delivery</option>
                <option value="cancelled">Cancelled</option>
                <option value="delivered">Delivered</option>
              </select>
            </div>
            <button onclick="updateStatus()" class="btn btn-primary w-full">Update Status</button>
          <% } %>
        </div>
      </div>

      <!-- Address & Items -->
      <div class="grid-2">
        <div class="card">
          <h4>Order Items</h4>
          <div class="table-container">
            <table class="order-item-table">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Qty</th>
                  <th>Price</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <% order.orderItems.forEach(item => { %>
                  <tr>
                    <td><%= item.product?.name || "Product deleted" %></td>
                    <td><%= item.quantity %></td>
                    <td>₹<%= item.unitPrice %></td>
                    <td>₹<%= item.unitPrice * item.quantity %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div class="mt-4 pt-3 border-top" style="text-align: right;">
            <div class="mb-1 text-muted">Subtotal: ₹<%= order.orderSummary.subTotal %></div>
            <div class="mb-2 text-muted">Product Discount: ₹<%= order.orderSummary.discount %></div>
            <div class="mb-2 text-muted">GST: ₹<%= order.orderSummary.GST%></div>
            <div class="mb-2 text-muted">Coupon Discount: ₹<%= order.orderSummary.coupon %></div>
            <div style="font-size: 1.25rem; font-weight: 800; color: var(--dark);">Total: ₹<%= order.orderSummary.total %></div>
          </div>
        </div>

        <div class="card">
          <h4>Shipping Address</h4>
          <div class="bg-light p-3 rounded" style="background-color: var(--gray-50); padding: 16px; border-radius: 12px;">
            <p style="font-weight: 500; font-size: 14px; line-height: 1.8;">
              <strong style="display: block; font-size: 16px; margin-bottom: 8px;"><%= order.shipping_address.name %></strong>
              <%= order.shipping_address.house %>, <%= order.shipping_address.streetName %><br>
              <%= order.shipping_address.city %>, <%= order.shipping_address.state %> - <%= order.shipping_address.pincode %>
            </p>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script>
async function updateStatus() {
  const orderId = document.getElementById("orderId").value;
  const status = document.getElementById("statusSelect").value;
  try {
    const res = await fetch("/admin/update-status", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ orderId, status })
    });
    const data = await res.json();
    if (data.success) {
      Toastify({ text: "✅ Status updated", duration: 2000, backgroundColor: "var(--success)" }).showToast();
      setTimeout(()=> location.reload(), 1000);
    } else {
      Toastify({ text: data.message || "Update failed", duration: 3000, backgroundColor: "var(--danger)" }).showToast();
    }
  } catch (err) {
    console.error(err);
  }
}
</script>
</body>
</html>
