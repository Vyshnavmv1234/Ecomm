<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Sales Analytics</title>

<style>

/* ================= GLOBAL ================= */
body{
    margin:0;
    font-family: Arial, Helvetica, sans-serif;
    background:#f4f6f9;
}
/* ===== REPORT TYPE SELECT ===== */

#reportType {
  padding: 10px 36px 10px 14px;
  border-radius: 8px;
  border: 1px solid #d1d5db;
  background-color: #ffffff;
  font-size: 14px;
  font-weight: 500;
  color: #374151;
  cursor: pointer;
  outline: none;
  transition: all 0.2s ease;

  /* Remove default arrow */
  appearance: none;
  -webkit-appearance: none;
  -moz-appearance: none;

  /* Custom arrow */
  background-image: url("data:image/svg+xml;utf8,<svg fill='%236b7280' height='20' viewBox='0 0 24 24' width='20' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/></svg>");
  background-repeat: no-repeat;
  background-position: right 10px center;
  background-size: 18px;
}

/* Hover */
#reportType:hover {
  border-color: #9ca3af;
}

/* Focus */
#reportType:focus {
  border-color: #007bff;
  box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
}

/* ================= ADMIN LAYOUT ================= */
/* Adjust according to your sidebar & header size */

.main-content{
    margin-left:270px;   /* sidebar width */
    margin-top:70px;     /* header height */
    padding:20px;
}

/* ================= HEADER SECTION ================= */
.page-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
}

.page-header h2{
    margin:0;
}

/* ================= BUTTON ================= */
.btn{
    padding:8px 14px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    font-weight:600;
}

.pdf{ background:#ff5252;color:white;}
.excel{ background:#28a745;color:white;}
.filterBtn{ background:#007bff;color:white;}

/* ================= FILTER ================= */
.filter-box{
    background:white;
    padding:15px;
    border-radius:10px;
    margin-bottom:20px;
    display:flex;
    gap:10px;
    align-items:center;
    flex-wrap:wrap;
}

select,input{
    padding:7px;
    border-radius:5px;
    border:1px solid #ccc;
}

/* ================= CARDS ================= */
.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:15px;
    margin-bottom:20px;
}

.card{
    background:white;
    padding:18px;
    border-radius:10px;
    box-shadow:0 2px 5px rgba(0,0,0,0.05);
}

.card h4{
    margin:0;
    color:#777;
}

.card h2{
    margin-top:8px;
}

.discount{
    color:red;
    font-weight:bold;
}

/* ================= CHART ================= */
.chart{
    background:white;
    padding:20px;
    border-radius:10px;
    margin-bottom:20px;
    text-align:center;
}

.donut{
    width:160px;
    height:160px;
    border-radius:50%;
    background:
    conic-gradient(
        orange 70%,
        #ddd 0
    );
    display:flex;
    align-items:center;
    justify-content:center;
    margin:auto;
}

.donut span{
    background:white;
    padding:30px;
    border-radius:50%;
    font-weight:bold;
}

/* ================= TABLE ================= */
.table-box{
    background:white;
    padding:20px;
    border-radius:10px;
}

table{
    width:100%;
    border-collapse:collapse;
}

th,td{
    padding:12px;
    text-align:left;
    border-bottom:1px solid #eee;
}

th{
    background:#fafafa;
}

</style>
</head>

<body>

<!-- ✅ HEADER -->
<%- include("../../views/partials/admin/header") %>

<!-- ✅ SIDEBAR -->
<%- include("../../views/partials/admin/sidebar") %>


<!-- ================= MAIN CONTENT ================= -->
<div class="main-content">

<!-- PAGE HEADER -->
<div class="page-header">
    <h2>Sales Analytics</h2>

    <div>
        <button class="btn pdf" onclick="exportPDF()">
         Export PDF
        </button>
        <button class="btn excel" onclick="exportExcel()">
          Export Excel
        </button>
    </div>
</div>


<!-- ================= FILTER ================= -->
<div class="filter-box">
 
<select id="reportType">
  <option value="daily">Daily</option>
  <option value="weekly">Weekly</option>
  <option value="monthly">Monthly</option>
  <option value="yearly">Yearly</option>
  <option value="custom">Custom</option>
</select>

<input type="date" id="fromDate">
<input type="date" id="toDate">

<button onclick="applyFilter()" class="btn filterBtn">
Apply Filter
</button>

</div>


<!-- ================= SALES CARDS ================= -->
<div class="cards">

<div class="card">
    <h4>Total Orders</h4>
    <h2 id="orderCount">0</h2>

</div>

<div class="card">
    <h4>Gross Sales</h4>
    <h2 id="grossSale">₹0</h2>

</div>

<div class="card">
    <h4>Coupon Discount</h4>
<h2 id="couponDiscount">₹0</h2>
</div>

<div class="card">
    <h4>Overall Discount</h4>
    <h2 id="overallDiscount">₹0</h2>
</div>

</div>


<!-- ================= ORDER TABLE ================= -->
<div class="table-box">

  

<div style="display:flex; gap:10px; margin-bottom:15px;">
  <button class="btn filterBtn" id="deliveredBtn"
          onclick="switchOrders('delivered')">
    Delivered Orders
  </button>

  <button class="btn" id="returnedBtn"
          onclick="switchOrders('returned')">
    Returned Orders
  </button>
</div>
<h3 id="tableTitle">Delivered Orders</h3>

<table >
<thead>
<tr>
<th>Order ID</th>
<th>Customer</th>
<th>Payment</th>
<th>Order Amount</th>
<th>Discount</th>
<th>Total</th>
<th>Date</th>
</tr>
</thead>

<tbody id="ordersTable">

<% if(orders.length > 0){ %>

  <% orders.forEach(order => { %>

    <tr>
      <td>#<%= order._id.toString().slice(-6).toUpperCase() %></td>

      <td>
        <%= order.userId?.name || "User" %>
      </td>

      <td>
        <%= order.paymentMethod %>
      </td>

      <td>
        ₹<%= order.orderSummary.subTotal +order.orderSummary.GST%>
      </td>

      <td class="discount">
        -₹
        <%= 
          order.orderSummary.discount +
          order.orderSummary.coupon
        %>
      </td>

      <td>
        ₹<%= order.orderSummary.total %>
      </td>

      <td>
        <%= new Date(order.createdAt)
              .toLocaleDateString("en-IN") %>
      </td>

    </tr>

  <% }) %>

<% } else { %>

<tr>
<td colspan="7" style="text-align:center;">
No Orders Found
</td>
</tr>

<% } %>

</tbody>
</table>

</div>

</div>

</body>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

  <script>

    function showToast(message, type = "error") {

  let bgColor = "#dc3545"; // red default

  if(type === "success") bgColor = "#28a745";
  if(type === "warning") bgColor = "#ffc107";
  if(type === "info") bgColor = "#007bff";

  Toastify({
    text: message,
    duration: 3000,
    gravity: "bottom",
    position: "center",
    backgroundColor: bgColor,
    close: true
  }).showToast();
}

    let currentOrderType = "delivered";
    function exportExcel(){

  const report =
    document.getElementById("reportType").value;

  const from =
    document.getElementById("fromDate").value;

  const to =
    document.getElementById("toDate").value;

  window.open(
   `/admin/analytics/export-excel?report=${report}&from=${from}&to=${to}`
  );
}
function switchOrders(type) {

  currentOrderType = type;

  // Button UI highlight
  document.getElementById("deliveredBtn").classList.remove("filterBtn");
  document.getElementById("returnedBtn").classList.remove("filterBtn");
  document.getElementById("tableTitle").innerText =
  type === "delivered"
    ? "Delivered Orders"
    : "Returned Orders";

  if (type === "delivered") {
    document.getElementById("deliveredBtn").classList.add("filterBtn");
  } else {
    document.getElementById("returnedBtn").classList.add("filterBtn");
  }

  applyFilter();
}

    function exportPDF(){

  const report =
    document.getElementById("reportType").value;

  const from =
    document.getElementById("fromDate").value;

  const to =
    document.getElementById("toDate").value;

  window.open(
   `/admin/analytics/export-pdf?report=${report}&from=${from}&to=${to}`,
   "_blank"
  );
}

async function applyFilter(){

  const report = document.getElementById("reportType").value;
  const from = document.getElementById("fromDate").value;
  const to = document.getElementById("toDate").value;

  if(report === "custom"){

    if(!from || !to){
      showToast("Please select both From and To dates", "warning");
      return;
    }

    const fromDate = new Date(from);
    const toDate = new Date(to);
    const today = new Date();
    today.setHours(0,0,0,0);

    if(fromDate > toDate){
      showToast("From date cannot be greater than To date", "error");
      return;
    }

    if(toDate > today){
      showToast("Future dates are not allowed", "error");
      return;
    }
  }
  const response = await fetch(
     `/admin/analytics-data?report=${report}&from=${from}&to=${to}&type=${currentOrderType}`
  );

  const data = await response.json();

  /* ===== UPDATE CARDS ===== */

  document.getElementById("orderCount")
    .innerText = data.orderCount;

  document.getElementById("grossSale")
    .innerText = "₹" + data.grossSale;

  document.getElementById("couponDiscount")
    .innerText = "₹" + data.couponDiscount;

  document.getElementById("overallDiscount")
    .innerText = "₹" + data.overallDiscount;

  /* ===== UPDATE TABLE ===== */

  const table = document.getElementById("ordersTable");

  table.innerHTML = "";

  data.orders.forEach(order => {

    table.innerHTML += `
      <tr>
        <td>#${order._id.slice(-6)}</td>
        <td>${order.userId?.name || "User"}</td>
        <td>${order.paymentMethod}</td>
        <td>₹${order.orderSummary.subTotal}</td>
        <td class="discount">
          -₹${order.orderSummary.discount +
              order.orderSummary.coupon}
        </td>
        <td>₹${order.orderSummary.total}</td>
        <td>
          ${new Date(order.createdAt)
            .toLocaleDateString("en-IN")}
        </td>
      </tr>
    `;
  });

}

</script>
<script>
window.onload = () => {
  applyFilter();   
};
</script>
</html>