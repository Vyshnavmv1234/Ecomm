<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Sales Analytics</title>

<style>

/* ================= GLOBAL ================= */
body{
    margin:0;
    font-family: Arial, Helvetica, sans-serif;
    background:#f4f6f9;
}

/* ================= ADMIN LAYOUT ================= */
/* Adjust according to your sidebar & header size */

.main-content{
    margin-left:270px;   /* sidebar width */
    margin-top:70px;     /* header height */
    padding:20px;
}

/* ================= HEADER SECTION ================= */
.page-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
}

.page-header h2{
    margin:0;
}

/* ================= BUTTON ================= */
.btn{
    padding:8px 14px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    font-weight:600;
}

.pdf{ background:#ff5252;color:white;}
.excel{ background:#28a745;color:white;}
.filterBtn{ background:#007bff;color:white;}

/* ================= FILTER ================= */
.filter-box{
    background:white;
    padding:15px;
    border-radius:10px;
    margin-bottom:20px;
    display:flex;
    gap:10px;
    align-items:center;
    flex-wrap:wrap;
}

select,input{
    padding:7px;
    border-radius:5px;
    border:1px solid #ccc;
}

/* ================= CARDS ================= */
.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:15px;
    margin-bottom:20px;
}

.card{
    background:white;
    padding:18px;
    border-radius:10px;
    box-shadow:0 2px 5px rgba(0,0,0,0.05);
}

.card h4{
    margin:0;
    color:#777;
}

.card h2{
    margin-top:8px;
}

.discount{
    color:red;
    font-weight:bold;
}

/* ================= CHART ================= */
.chart{
    background:white;
    padding:20px;
    border-radius:10px;
    margin-bottom:20px;
    text-align:center;
}

.donut{
    width:160px;
    height:160px;
    border-radius:50%;
    background:
    conic-gradient(
        orange 70%,
        #ddd 0
    );
    display:flex;
    align-items:center;
    justify-content:center;
    margin:auto;
}

.donut span{
    background:white;
    padding:30px;
    border-radius:50%;
    font-weight:bold;
}

/* ================= TABLE ================= */
.table-box{
    background:white;
    padding:20px;
    border-radius:10px;
}

table{
    width:100%;
    border-collapse:collapse;
}

th,td{
    padding:12px;
    text-align:left;
    border-bottom:1px solid #eee;
}

th{
    background:#fafafa;
}

</style>
</head>

<body>

<!-- ✅ HEADER -->
<%- include("../../views/partials/admin/header") %>

<!-- ✅ SIDEBAR -->
<%- include("../../views/partials/admin/sidebar") %>


<!-- ================= MAIN CONTENT ================= -->
<div class="main-content">

<!-- PAGE HEADER -->
<div class="page-header">
    <h2>Sales Analytics</h2>

    <div>
        <button class="btn pdf" onclick="exportPDF()">
         Export PDF
        </button>
        <button class="btn excel" onclick="exportExcel()">
          Export Excel
        </button>
    </div>
</div>


<!-- ================= FILTER ================= -->
<div class="filter-box">
 
<select id="reportType">
  <option value="daily">Daily</option>
  <option value="weekly">Weekly</option>
  <option value="yearly">Yearly</option>
  <option value="custom">Custom</option>
</select>

<input type="date" id="fromDate">
<input type="date" id="toDate">

<button onclick="applyFilter()" class="btn filterBtn">
Apply Filter
</button>

</div>


<!-- ================= SALES CARDS ================= -->
<div class="cards">

<div class="card">
    <h4>Total Orders</h4>
    <h2 id="orderCount">0</h2>

</div>

<div class="card">
    <h4>Gross Sales</h4>
    <h2 id="grossSale">₹0</h2>

</div>

<div class="card">
    <h4>Coupon Discount</h4>
<h2 id="couponDiscount">₹0</h2>
</div>

<div class="card">
    <h4>Overall Discount</h4>
    <h2 id="overallDiscount">₹0</h2>
</div>

</div>


<!-- ================= ORDER TABLE ================= -->
<div class="table-box">

<h3>Delivered Orders</h3>

<table >
<thead>
<tr>
<th>Order ID</th>
<th>Customer</th>
<th>Payment</th>
<th>Order Amount</th>
<th>Discount</th>
<th>Total</th>
<th>Date</th>
</tr>
</thead>

<tbody id="ordersTable">

<% if(orders.length > 0){ %>

  <% orders.forEach(order => { %>

    <tr>
      <td>#<%= order._id.toString().slice(-6).toUpperCase() %></td>

      <td>
        <%= order.userId?.name || "User" %>
      </td>

      <td>
        <%= order.paymentMethod %>
      </td>

      <td>
        ₹<%= order.orderSummary.subTotal +order.orderSummary.GST%>
      </td>

      <td class="discount">
        -₹
        <%= 
          order.orderSummary.discount +
          order.orderSummary.coupon
        %>
      </td>

      <td>
        ₹<%= order.orderSummary.total %>
      </td>

      <td>
        <%= new Date(order.createdAt)
              .toLocaleDateString("en-IN") %>
      </td>

    </tr>

  <% }) %>

<% } else { %>

<tr>
<td colspan="7" style="text-align:center;">
No Orders Found
</td>
</tr>

<% } %>

</tbody>
</table>

</div>

</div>

</body>

  <script>
    function exportExcel(){

  const report =
    document.getElementById("reportType").value;

  const from =
    document.getElementById("fromDate").value;

  const to =
    document.getElementById("toDate").value;

  window.open(
   `/admin/analytics/export-excel?report=${report}&from=${from}&to=${to}`
  );
}

    function exportPDF(){

  const report =
    document.getElementById("reportType").value;

  const from =
    document.getElementById("fromDate").value;

  const to =
    document.getElementById("toDate").value;

  window.open(
   `/admin/analytics/export-pdf?report=${report}&from=${from}&to=${to}`,
   "_blank"
  );
}

async function applyFilter(){

  const report =
    document.getElementById("reportType").value;

  const from =
    document.getElementById("fromDate").value;

  const to =
    document.getElementById("toDate").value;

  const response = await fetch(
    `/admin/analytics-data?report=${report}&from=${from}&to=${to}`
  );

  const data = await response.json();

  /* ===== UPDATE CARDS ===== */

  document.getElementById("orderCount")
    .innerText = data.orderCount;

  document.getElementById("grossSale")
    .innerText = "₹" + data.grossSale;

  document.getElementById("couponDiscount")
    .innerText = "₹" + data.couponDiscount;

  document.getElementById("overallDiscount")
    .innerText = "₹" + data.overallDiscount;

  /* ===== UPDATE TABLE ===== */

  const table = document.getElementById("ordersTable");

  table.innerHTML = "";

  data.orders.forEach(order => {

    table.innerHTML += `
      <tr>
        <td>#${order._id.slice(-6)}</td>
        <td>${order.userId?.name || "User"}</td>
        <td>${order.paymentMethod}</td>
        <td>₹${order.orderSummary.subTotal}</td>
        <td class="discount">
          -₹${order.orderSummary.discount +
              order.orderSummary.coupon}
        </td>
        <td>₹${order.orderSummary.total}</td>
        <td>
          ${new Date(order.createdAt)
            .toLocaleDateString("en-IN")}
        </td>
      </tr>
    `;
  });

}

</script>
<script>
window.onload = () => {
  applyFilter();   
};
</script>
</html>