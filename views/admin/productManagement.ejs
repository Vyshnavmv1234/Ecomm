<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>WestLane | Products</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Global Styles -->
  <%- include("../../views/partials/admin/adminStyles") %>
  
  <style>
    /* Page specific overrides */
    .product-img {
      width: 48px;
      height: 48px;
      object-fit: cover;
      border-radius: 10px;
      background: var(--gray-100);
      border: 1px solid var(--gray-200);
    }
    
    .search-input {
      max-width: 400px;
    }
  </style>
</head>

<body>
  
<div class="layout">
  <!-- SIDEBAR -->
  <%- include("../../views/partials/admin/sidebar") %>

  <!-- CONTENT -->
  <div class="content">
    <!-- HEADER -->
    <%- include("../../views/partials/admin/header") %>

    <!-- MAIN -->
    <main class="main">
      
      <!-- PAGE HEADER -->
      <div class="d-flex justify-between align-center mb-4">
        <div>
          <h2>Products Management</h2>
          <nav class="text-muted d-flex gap-2">
            <a href="/admin/adminDashboard" style="color: var(--primary); text-decoration: none;">Dashboard</a>
            <span>/</span>
            <span>Products</span>
          </nav>
        </div>
        <a href="/admin/addProducts" class="btn btn-primary">
          <i class="fas fa-plus"></i> Add New Product
        </a>
      </div>

      <!-- SEARCH & FILTERS -->
      <div class="card d-flex justify-between align-center">
        <form method="get" action="/admin/products" class="search-input">
          <div class="d-flex gap-2">
            <input name="search" type="text" placeholder="Search products..." value="<%= search %>" />
            <button type="submit" class="btn btn-outline">
              <i class="fas fa-search"></i>
            </button>
          </div>
        </form>
        <div class="d-flex gap-2">
          <select class="form-select" style="width: auto;">
            <option>All Status</option>
            <option>Active</option>
            <option>Blocked</option>
          </select>
        </div>
      </div>

      <!-- PRODUCTS TABLE -->
      <div class="card">
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Product Info</th>
                <th>Category</th>
                <th>Base Price</th>
                <th>Total Stock</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (products.length === 0) { %>
                <tr>
                  <td colspan="6" style="text-align:center; padding:40px;">
                    <i class="fas fa-box-open" style="font-size: 40px; color: var(--gray-300); margin-bottom: 15px; display: block;"></i>
                    <p class="text-muted">No products found match your search.</p>
                  </td>
                </tr>
              <% } %>

              <% products.forEach(product => { %>
                <tr>
                  <td>
                    <div class="d-flex align-center gap-3">
                      <% if (product.images && product.images.length > 0) { %>
                        <img src="<%= product.images[0].url %>" class="product-img" alt="product" />
                      <% } else { %>
                        <div class="product-img d-flex align-center justify-center">
                          <i class="fas fa-image text-muted"></i>
                        </div>
                      <% } %>
                      <div>
                        <div style="font-weight: 600; color: var(--dark);"><%= product.name %></div>
                        <div class="text-muted" style="font-size: 12px;">ID: <%= product._id.toString().slice(-6).toUpperCase() %></div>
                      </div>
                    </div>
                  </td>

                  <td>
                    <span class="badge badge-info"><%= product.category?.name || "Uncategorized" %></span>
                  </td>

                  <td style="font-weight: 600; color: var(--dark);">₹<%= product.variants[0].price.toLocaleString() %></td>

                  <td>
                    <div class="d-flex align-center gap-2">
                      <div style="width: 8px; height: 8px; border-radius: 50%; background-color: <%= product.totalStock > 10 ? 'var(--success)' : 'var(--warning)' %>;"></div>
                      <span><%= product.totalStock %> units</span>
                    </div>
                  </td>

                  <td>
                    <% if (product.isBlocked) { %>
                      <span class="badge badge-danger">Blocked</span>
                    <% } else { %>
                      <span class="badge badge-success">Active</span>
                    <% } %>
                  </td>

                  <td>
                    <div class="d-flex gap-2 text-center" style="justify-content: center;">
                      <a href="/admin/editProduct/<%= product._id %>" class="btn btn-outline" style="padding: 8px; border-radius: 8px;" title="Edit Product">
                        <i class="fas fa-edit"></i>
                      </a>
                      
                      <% if (product.isBlocked) { %>
                        <button onclick="unblockProduct('<%= product._id %>')" class="btn btn-success" style="padding: 8px; border-radius: 8px;" title="Unblock">
                          <i class="fas fa-unlock"></i>
                        </button>
                      <% } else { %>
                        <button onclick="blockProduct('<%= product._id %>')" class="btn btn-danger" style="padding: 8px; border-radius: 8px;" title="Block">
                          <i class="fas fa-ban"></i>
                        </button>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- PAGINATION -->
        <% if (totalPages > 1) { %>
          <div class="pagination">
            <% if (currentPage > 1) { %>
              <a class="page-link" href="?page=<%= currentPage - 1 %>&search=<%= search %>">
                <i class="fas fa-chevron-left"></i>
              </a>
            <% } %>

            <% for (let i = 1; i <= totalPages; i++) { %>
              <a class="page-link <%= i === currentPage ? 'active' : '' %>" href="?page=<%= i %>&search=<%= search %>">
                <%= i %>
              </a>
            <% } %>

            <% if (currentPage < totalPages) { %>
              <a class="page-link" href="?page=<%= currentPage + 1 %>&search=<%= search %>">
                <i class="fas fa-chevron-right"></i>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </main>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  async function blockProduct(productId) {
    const confirmAction = await Swal.fire({
      title: "Block this product?",
      text: "Users will not be able to purchase it.",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#ef4444",
      cancelButtonColor: "#64748b",
      confirmButtonText: "Yes, Block",
      cancelButtonText: "Cancel",
      reverseButtons: true
    });
    if (!confirmAction.isConfirmed) return;
    try {
      const res = await fetch(`/admin/blockProduct/${productId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" }
      });
      const data = await res.json();
      if (data.success) {
        await Swal.fire({ icon: "success", title: "Blocked", text: "Product has been blocked", timer: 1500, showConfirmButton: false });
        location.reload();
      } else {
        Swal.fire({ icon: "error", title: "Failed", text: data.message || "Failed to block product" });
      }
    } catch (error) {
      console.error(error);
      Swal.fire({ icon: "error", title: "Server Error", text: "Something went wrong" });
    }
  }

  async function unblockProduct(productId) {
    const confirmAction = await Swal.fire({
      title: "Unblock this product?",
      text: "Users will be able to purchase it again.",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#10b981",
      cancelButtonColor: "#64748b",
      confirmButtonText: "Yes, Unblock",
      cancelButtonText: "Cancel",
      reverseButtons: true
    });
    if (!confirmAction.isConfirmed) return;
    try {
      const res = await fetch(`/admin/unblockProduct/${productId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" }
      });
      const data = await res.json();
      if (data.success) {
        await Swal.fire({ icon: "success", title: "Unblocked", text: "Product has been unblocked", timer: 1500, showConfirmButton: false });
        location.reload();
      } else {
        Swal.fire({ icon: "error", title: "Failed", text: data.message || "Failed to unblock product" });
      }
    } catch (error) {
      console.error(error);
      Swal.fire({ icon: "error", title: "Server Error", text: "Something went wrong" });
    }
  }
</script>

</body>
</html>
