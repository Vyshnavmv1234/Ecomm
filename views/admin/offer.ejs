<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>WestLane | Offers</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Global Styles -->
  <%- include("../../views/partials/admin/adminStyles") %>
  
  <style>
    .search-container { max-width: 350px; }
    .duration-info { font-size: 0.75rem; display: flex; flex-direction: column; gap: 2px; }
    .status-badge { display: flex; align-items: center; gap: 6px; font-weight: 600; }
    /* Fix for overlapping elements blocking clicks */
    .content { position: relative; z-index: 1; }
    .card { position: relative; z-index: 2; }
    .btn { position: relative; z-index: 5; } /* Heighten buttons to stay above card z-index */
  </style>
</head>

<body>
  
<div class="layout">
  <!-- SIDEBAR -->
  <%- include("../../views/partials/admin/sidebar") %>

  <!-- CONTENT -->
  <div class="content">
    <!-- HEADER -->
    <%- include("../../views/partials/admin/header") %>

    <!-- MAIN -->
    <main class="main">
      
      <!-- PAGE HEADER -->
      <div class="d-flex justify-between align-center mb-4">
        <div>
          <h2>Offers Management</h2>
          <nav class="text-muted d-flex gap-2">
            <a href="/admin/adminDashboard" style="color: var(--primary); text-decoration: none;">Dashboard</a>
            <span>/</span>
            <span>Offers</span>
          </nav>
        </div>
        <button class="btn btn-primary" onclick="openOfferModal()">
          <i class="fas fa-plus"></i> Add <%= offerType.charAt(0).toUpperCase() + offerType.slice(1) %> Offer
        </button>
      </div>

      <!-- TABS & SEARCH -->
      <div class="card">
        <div class="d-flex justify-between align-center flex-wrap gap-3">
          <div class="filter-bar mb-0">
            <a href="/admin/offers?type=product" class="filter-btn <%= offerType === 'product' ? 'active' : '' %>">Product Offers</a>
            <a href="/admin/offers?type=category" class="filter-btn <%= offerType === 'category' ? 'active' : '' %>">Category Offers</a>
          </div>
          
          <form method="GET" action="/admin/offers" class="search-container w-full">
            <div class="d-flex gap-2">
              <input name="search" type="text" placeholder="Search offers..." value="<%= search %>" />
              <input type="hidden" name="type" value="<%= offerType %>">
              <button type="submit" class="btn btn-outline">
                <i class="fas fa-search"></i>
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- OFFERS TABLE -->
      <div class="card">
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Offer Details</th>
                <th>Target <%= offerType === "category" ? "Category" : "Product" %></th>
                <th>Discount</th>
                <th>Duration</th>
                <th>Status</th>
                <th style="text-align: right;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (offers && offers.length > 0) { %>
                <% offers.forEach(offer => { %>
                  <% 
                    const today = new Date(); today.setHours(0,0,0,0);
                    const start = new Date(offer.startDate); start.setHours(0,0,0,0);
                    const end = new Date(offer.endDate); end.setHours(23,59,59,999);
                    const isActive = offer.isActive && today >= start && today <= end;
                  %>
                  <tr>
                    <td>
                      <div style="font-weight: 600; color: var(--dark);"><%= offer.title %></div>
                      <div class="text-muted" style="font-size: 12px;">ID: <%= offer._id.toString().slice(-6).toUpperCase() %></div>
                    </td>
                    <td style="font-weight: 500;">
                      <% if (offerType === "product") { %>
                        <%= offer.product?.name || "-" %>
                      <% } else { %>
                        <span class="badge badge-info"><%= offer.category?.name || "-" %></span>
                      <% } %>
                    </td>
                    <td>
                      <span class="badge badge-danger" style="font-weight: 700;">
                        <%= offer.discountType === "percentage" ? offer.discountValue + "% OFF" : "₹" + offer.discountValue + " OFF" %>
                      </span>
                    </td>
                    <td>
                      <div class="duration-info">
                        <span style="color: var(--success);"><i class="far fa-calendar-check mr-1"></i> <%= offer.startDate.toLocaleDateString("en-IN") %></span>
                        <span style="color: var(--danger);"><i class="far fa-calendar-times mr-1"></i> <%= offer.endDate.toLocaleDateString("en-IN") %></span>
                      </div>
                    </td>
                    <td>
                      <% if (isActive) { %>
                        <span class="badge badge-success">Active</span>
                      <% } else { %>
                        <span class="badge badge-danger">Expired/Inactive</span>
                      <% } %>
                    </td>
                    <td>
                      <div class="d-flex gap-2 justify-end">
                        <button class="btn btn-outline btn-sm" onclick='openEditModal("<%=offer._id%>", "<%=offer.title%>", "<%=offer.discountValue%>", "<%=offer.startDate.toISOString().split("T")[0]%>", "<%=offer.endDate.toISOString().split("T")[0]%>", "<%=offer.product?._id || ""%>", "<%=offer.category?._id || ""%>")'>
                          <i class="fas fa-edit"></i> Edit
                        </button>
                        <button onclick="toggleOffer('<%=offer._id%>', '<%=offer.isActive%>')" class="btn <%= offer.isActive ? 'btn-danger' : 'btn-success' %> btn-sm">
                          <% if(offer.isActive){ %>
                            <i class="fas fa-eye-slash"></i> Unlist
                          <% } else { %>
                            <i class="fas fa-eye"></i> List
                          <% } %>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" style="text-align:center; padding:40px;">
                    <i class="fas fa-gift" style="font-size: 40px; color: var(--gray-300); margin-bottom: 15px; display: block;"></i>
                    <p class="text-muted">No offers found.</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- PAGINATION -->
        <% if (totalPages > 1) { %>
          <div class="pagination">
            <% if (currentPage > 1) { %>
              <a class="page-link" href="/admin/offers?type=<%=offerType%>&search=<%=search%>&page=<%=currentPage-1%>">
                <i class="fas fa-chevron-left"></i>
              </a>
            <% } %>

            <% for (let i = 1; i <= totalPages; i++) { %>
              <a class="page-link <%= i === currentPage ? 'active' : '' %>" href="/admin/offers?type=<%=offerType%>&search=<%=search%>&page=<%=i%>">
                <%= i %>
              </a>
            <% } %>

            <% if (currentPage < totalPages) { %>
              <a class="page-link" href="/admin/offers?type=<%=offerType%>&search=<%=search%>&page=<%=currentPage+1%>">
                <i class="fas fa-chevron-right"></i>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </main>
  </div>
</div>

<!-- OFFER MODAL -->
<div id="offerModal" class="modal">
  <div class="modal-content" style="max-width: 600px;">
    <span class="close" onclick="closeOfferModal()">&times;</span>
    <div class="modal-header mb-4">
      <h3 id="modalTitle">Add Offer</h3>
      <p class="text-muted" style="font-size: 0.875rem;">Create a new promotion for your products or categories.</p>
    </div>
    
    <form id="offerForm">
      <input type="hidden" name="type" value="<%= offerType %>">
      
      <div class="form-group">
        <label>Offer Title</label>
        <input name="title" placeholder="e.g. Summer Special Sale" required>
        <div class="text-danger" id="titleError" style="font-size: 11px; margin-top: 4px;"></div>
      </div>

      <% if (offerType === "product") { %>
        <div class="form-group">
          <label>Target Product</label>
          <select name="product" required>
            <option value="">-- Select a Product --</option>
            <% products.forEach(p => { %>
              <option value="<%= p._id %>"><%= p.name %></option>
            <% }) %>
          </select>
          <div class="text-danger" id="productError" style="font-size: 11px; margin-top: 4px;"></div>
        </div>
      <% } else { %>
        <div class="form-group">
          <label>Target Category</label>
          <select name="category" required>
            <option value="">-- Select a Category --</option>
            <% categories.forEach(c => { %>
              <option value="<%= c._id %>"><%= c.name %></option>
            <% }) %>
          </select>
          <div class="text-danger" id="categoryError" style="font-size: 11px; margin-top: 4px;"></div>
        </div>
      <% } %>

      <div class="d-flex gap-3">
        <div class="form-group" style="flex: 2;">
          <label>Discount Value</label>
          <input type="number" name="discountValue" placeholder="Amount" required>
        </div>
        <div class="form-group" style="flex: 1;">
          <label>Type</label>
          <select name="discountType">
            <option value="percentage">Percentage (%)</option>
            <option value="flat">Flat Amount (₹)</option>
          </select>
        </div>
      </div>
      <div class="text-danger mb-3" id="discountError" style="font-size: 11px; margin-top: -15px;"></div>

      <div class="d-flex gap-3">
        <div class="form-group" style="flex: 1;">
          <label>Start Date</label>
          <input type="date" name="startDate" id="startDate" required>
        </div>
        <div class="form-group" style="flex: 1;">
          <label>End Date</label>
          <input type="date" name="endDate" id="endDate" required>
        </div>
      </div>
      <div class="text-danger mb-4" id="dateError" style="font-size: 11px; margin-top: -15px;"></div>

      <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closeOfferModal()">Cancel</button>
        <button type="submit" class="btn btn-primary" style="flex: 2;" id="submitBtn">Save Offer</button>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
const offerModal = document.getElementById("offerModal");
const offerForm = document.getElementById("offerForm");

function openOfferModal() {
    document.getElementById("modalTitle").innerText = "Add Offer";
    document.getElementById("submitBtn").innerText = "Create Offer";
    offerModal.style.display = "flex";
}

function closeOfferModal() {
    offerModal.style.display = "none";
    offerForm.reset();
    clearErrors();
    delete offerForm.dataset.editId;
}

function clearErrors(){
    document.querySelectorAll(".text-danger").forEach(e => e.innerText = "");
}

function validateForm(f){
    let valid = true;
    clearErrors();
    const title = f.title.value.trim();
    const discount = Number(f.discountValue.value);
    const startDate = f.startDate.value;
    const endDate = f.endDate.value;
    const type = f.type.value;

    if(!title){ document.getElementById("titleError").innerText = "Title is required"; valid = false; }
    if(type === "product" && f.product && !f.product.value){ document.getElementById("productError").innerText = "Select a product"; valid = false; }
    if(type === "category" && f.category && !f.category.value){ document.getElementById("categoryError").innerText = "Select a category"; valid = false; }
    if(!discount || discount <= 0){ document.getElementById("discountError").innerText = "Discount must be positive"; valid = false; }
    
    if (!startDate || !endDate) {
        document.getElementById("dateError").innerText = "Dates are required";
        valid = false;
    } else {
        const start = new Date(startDate); start.setHours(0,0,0,0);
        const end = new Date(endDate); end.setHours(23,59,59,999);
        const today = new Date(); today.setHours(0,0,0,0);
        if (start < today && !offerForm.dataset.editId) { document.getElementById("dateError").innerText = "Start date cannot be in past"; valid = false; }
        else if (end <= start) { document.getElementById("dateError").innerText = "End date must be after start date"; valid = false; }
    }
    return valid;
}

offerForm.addEventListener("submit", async(e)=>{
    e.preventDefault();
    const f = e.target;
    if(!validateForm(f)) return;

    const data = {
        title: f.title.value.trim(),
        product: f.product?.value || null,
        category: f.category?.value || null,
        discountType: f.discountType.value,
        discountValue: Number(f.discountValue.value),
        startDate: f.startDate.value,
        endDate: f.endDate.value,
        type: f.type.value
    };

    try{
        let url = "/admin/offer/addOffer";
        let method = "POST";
        if(offerForm.dataset.editId){
            url = `/admin/offer/edit/${offerForm.dataset.editId}`;
            method = "PUT";
        }

        const res = await fetch(url, {
            method,
            headers: { "Content-Type":"application/json" },
            body: JSON.stringify(data)
        });
        const result = await res.json();
        if(result.success){
            Swal.fire({ icon: "success", title: "Saved!", text: result.message, timer: 1500, showConfirmButton: false }).then(()=> location.reload());
        } else {
            Swal.fire({ icon: "error", title: "Error", text: result.message || "Failed" });
        }
    } catch(err){
        Swal.fire({ icon: "error", title: "Server Error", text: "Something went wrong" });
    }
});

function openEditModal(id,title,discount,start,end,product,category){
    openOfferModal();
    document.getElementById("modalTitle").innerText = "Edit Offer";
    document.getElementById("submitBtn").innerText = "Update Offer";
    offerForm.title.value = title;
    offerForm.discountValue.value = discount;
    offerForm.startDate.value = start;
    offerForm.endDate.value = end;
    if(product && offerForm.product) offerForm.product.value = product;
    if(category && offerForm.category) offerForm.category.value = category;
    offerForm.dataset.editId = id;
}

async function toggleOffer(id,isActive){
    const action = isActive === "true" ? "unlist" : "list";
    const result = await Swal.fire({
        title: `Do you want to ${action} this offer?`,
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "var(--primary)",
        cancelButtonColor: "var(--danger)",
        confirmButtonText: "Yes, proceed",
        reverseButtons: true
    });
    if(!result.isConfirmed) return;
    try{
        const res = await fetch(`/admin/offer/toggle/${id}`, { method:"PATCH" });
        const result = await res.json();
        if(result.success){
            await Swal.fire({ icon: "success", title: "Success", text: result.message, timer: 1500, showConfirmButton: false });
            location.reload();
        } else {
            Swal.fire({ icon: "error", title: "Error", text: result.message });
        }
    } catch(err){
        Swal.fire({ icon: "error", title: "Server Error", text: "Something went wrong" });
    }
}

window.onclick = function(e){ if(e.target === offerModal) closeOfferModal(); };
</script>

</body>
</html>