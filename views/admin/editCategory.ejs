<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>WestLane | Edit Category</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<%- include("../../views/partials/admin/adminStyles") %>

<style>
/* CUSTOM PAGE STYLES */
.form-grid {
  margin-top: 22px;
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 24px;
}

.upload-box {
  border: 2px dashed var(--gray-200);
  border-radius: 14px;
  padding: 30px 16px;
  text-align: center;
  background: var(--gray-50);
  cursor: pointer;
  transition: var(--transition);
}

.upload-box:hover {
  border-color: var(--primary);
  background: white;
}

#previewImage {
  width: 100%;
  max-height: 200px;
  object-fit: contain;
  border-radius: 8px;
  margin-bottom: 12px;
}

@media (max-width: 1024px) {
  .form-grid { grid-template-columns: 1fr; }
}
</style>
</head>

<body>
  
<div class="layout">
  <!-- SIDEBAR -->
  <%- include("../../views/partials/admin/sidebar") %>

  <!-- CONTENT -->
  <div class="content">
    <!-- HEADER -->
    <%- include("../../views/partials/admin/header") %>

    <!-- MAIN -->
    <main class="main">
      <div class="d-flex justify-between align-center mb-4">
        <div>
          <h2>Edit Category</h2>
          <nav class="text-muted d-flex gap-2">
            <a href="/admin/category" style="color: var(--primary); text-decoration: none;">Categories</a>
            <span>/</span>
            <span>Edit</span>
          </nav>
        </div>
      </div>

      <!-- FORM CONTENT -->
      <form id="editCategoryForm">
        <div class="form-grid">
          <!-- THUMBNAIL -->
          <div class="card">
            <h4 class="mb-3">Thumbnail</h4>
            <div class="upload-box" id="uploadBox">
              <img id="previewImage" src="<%= categoryData.image %>" alt="Category Image" />
              <input type="file" id="imageInput" name="image" hidden accept="image/*" />
              <button type="button" class="btn btn-outline btn-sm w-full" id="changeImageBtn">
                <i class="fas fa-camera"></i> Change Photo
              </button>
            </div>
          </div>

          <!-- GENERAL INFO -->
          <div class="card">
            <h4 class="mb-4">General Information</h4>
            <div class="form-group mb-4">
              <label for="categoryName">Category Name</label>
              <input id="categoryName" type="text" value="<%= categoryData.name %>" required />
            </div>

            <div class="d-flex gap-2 align-center">
              <button type="submit" id="saveBtn" class="btn btn-primary">
                <i class="fas fa-save"></i> Save Changes
              </button>
              <a href="/admin/category" class="btn btn-outline">Cancel</a>
            </div>

            <div class="mt-3">
              <small id="successMsg" style="color:var(--success); display:none;"></small>
              <small id="errorMsg" style="color:var(--danger); display:none;"></small>
            </div>
          </div>
        </div>
      </form>
    </main>
  </div>
</div>

<script>
const form = document.getElementById("editCategoryForm")
const imageInput = document.getElementById("imageInput")
const previewImage = document.getElementById("previewImage")
const changeImageBtn = document.getElementById("changeImageBtn")
const successMsg = document.getElementById("successMsg")
const errorMsg = document.getElementById("errorMsg")
const saveBtn = document.getElementById("saveBtn")
const categoryId = "<%= categoryData._id %>"

changeImageBtn.addEventListener("click", () => imageInput.click())

imageInput.addEventListener("change", () => {
  const file = imageInput.files[0]
  if (file) previewImage.src = URL.createObjectURL(file)
})

form.addEventListener("submit", async (e) => {
  e.preventDefault()
  const catName = document.getElementById("categoryName").value.trim()
  if (catName.length < 3) {
    errorMsg.textContent = "Category name must be at least 3 characters"
    errorMsg.style.display = "block"
    return
  }

  saveBtn.disabled = true
  saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
  
  const formData = new FormData()
  formData.append("categoryName", catName)
  if (imageInput.files[0]) formData.append("image", imageInput.files[0])

  try {
    const res = await fetch(`/admin/category/update/${categoryId}`, {
      method: "PATCH",
      body: formData
    })
    const data = await res.json()
    if (res.ok && data.success) {
      successMsg.textContent = "Category updated successfully!"
      successMsg.style.display = "block"
      setTimeout(() => { window.location.href = "/admin/category" }, 1200)
    } else {
      errorMsg.textContent = data.message
      errorMsg.style.display = "block"
      saveBtn.disabled = false
      saveBtn.innerHTML = '<i class="fas fa-save"></i> Save Changes';
    }
  } catch (err) {
    errorMsg.textContent = "Something went wrong"
    errorMsg.style.display = "block"
    saveBtn.disabled = false
    saveBtn.innerHTML = '<i class="fas fa-save"></i> Save Changes';
  }
})
</script>
</body>
</html>
