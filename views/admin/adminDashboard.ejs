<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>WestLane | Admin Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Global Styles -->
  <%- include("../../views/partials/admin/adminStyles") %>
  
  <style>
    /* Dashboard-specific Stat Cards (Gradients) */
    .stat-cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 24px;
      margin-bottom: 32px;
    }

    .stat-card-gradient {
      position: relative;
      padding: 24px;
      border-radius: 20px;
      color: white;
      overflow: hidden;
      box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.1);
      transition: var(--transition);
      border: none;
    }

    .stat-card-gradient:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 30px -10px rgba(0, 0, 0, 0.2);
    }

    .stat-card-gradient.blue { background: linear-gradient(135deg, #4361ee, #4895ef); }
    .stat-card-gradient.purple { background: linear-gradient(135deg, #7209b7, #b5179e); }
    .stat-card-gradient.green { background: linear-gradient(135deg, #10b981, #34d399); }

    .stat-icon {
      position: absolute;
      right: -10px;
      bottom: -10px;
      font-size: 80px;
      opacity: 0.15;
    }

    .stat-meta {
      font-size: 12px;
      opacity: 0.8;
      margin-top: 15px;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    /* Progress List for Top Performers */
    .progress-list { margin-top: 10px; }
    .progress-item { margin-bottom: 20px; }
    .progress-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .progress-name { font-size: 14px; font-weight: 500; color: var(--gray-700); }
    .progress-percent { font-size: 13px; font-weight: 700; color: var(--primary); }
    .progress-bar-bg { height: 8px; background: var(--gray-100); border-radius: 10px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--primary-light)); border-radius: 10px; transition: width 1s cubic-bezier(0.4, 0, 0.2, 1); width: 0; }

    .grid-2 {
      display: grid;
      grid-template-columns: 1.6fr 1fr;
      gap: 24px;
    }

    @media (max-width: 1024px) {
      .grid-2 { grid-template-columns: 1fr; }
    }
  </style>
</head>

<body>
  
<div class="layout">
  <!-- SIDEBAR -->
  <%- include("../../views/partials/admin/sidebar") %>

  <!-- CONTENT -->
  <div class="content">
    <!-- HEADER -->
    <%- include("../../views/partials/admin/header") %>

    <!-- MAIN -->
    <main class="main">
      
      <!-- WELCOME SECTION -->
      <div class="d-flex justify-between align-center mb-4">
        <div>
          <h2 class="mb-1" style="font-weight: 700;">Dashboard Overview</h2>
          <p class="text-muted">Real-time insights and business performance analytics.</p>
        </div>
        <div class="d-flex gap-2">
          <select id="frequency" class="form-select" style="width: auto; min-width: 140px;">
            <option value="daily">Daily View</option>
            <option value="weekly">Weekly View</option>
            <option value="monthly" selected>Monthly View</option>
            <option value="yearly">Yearly View</option>
          </select>
        </div>
      </div>

      <!-- STAT CARDS -->
      <div class="stat-cards-grid">
        <div class="stat-card-gradient blue">
          <div class="stat-icon"><i class="fas fa-shopping-cart"></i></div>
          <p style="font-size: 13px; font-weight: 500; opacity: 0.9; margin-bottom: 8px;">TOTAL SALES</p>
          <h2 style="font-size: 32px; font-weight: 700; margin: 0;" id="sales">0</h2>
          <div class="stat-meta">
            <i class="fas fa-chart-line"></i> orders processed
          </div>
        </div>

        <div class="stat-card-gradient purple">
          <div class="stat-icon"><i class="fas fa-wallet"></i></div>
          <p style="font-size: 13px; font-weight: 500; opacity: 0.9; margin-bottom: 8px;">TOTAL REVENUE</p>
          <h2 style="font-size: 32px; font-weight: 700; margin: 0;" id="rev">₹0</h2>
          <div class="stat-meta">
            <i class="fas fa-coins"></i> net earnings
          </div>
        </div>

        <div class="stat-card-gradient green">
          <div class="stat-icon"><i class="fas fa-users"></i></div>
          <p style="font-size: 13px; font-weight: 500; opacity: 0.9; margin-bottom: 8px;">ACTIVE USERS</p>
          <h2 style="font-size: 32px; font-weight: 700; margin: 0;" id="users">0</h2>
          <div class="stat-meta">
            <i class="fas fa-user-plus"></i> joined WestLane
          </div>
        </div>
      </div>

      <!-- MAIN GRID -->
      <div class="grid-2">
        
        <!-- REVENUE CHART -->
        <div class="card">
          <div class="d-flex justify-between align-center mb-4">
            <h4 style="margin: 0; font-weight: 700;">Revenue Analysis</h4>
            <div class="badge badge-info">Live Stream</div>
          </div>
          <div style="height: 380px; width: 100%;">
            <canvas id="revenueChart"></canvas>
          </div>
        </div>

        <!-- TOP PERFORMERS -->
        <div class="card">
          <div class="d-flex justify-between align-center mb-4">
            <h4 style="margin: 0; font-weight: 700;">Top Performers</h4>
            <select id="typeFilter" class="form-select" style="width: auto; padding: 4px 30px 4px 10px; font-size: 12px;">
              <option value="product" selected>By Products</option>
              <option value="category">By Categories</option>
            </select>
          </div>
          <div id="topProducts" class="progress-list">
            <!-- Dynamic content via JS -->
          </div>
        </div>

      </div>
    </main>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  let revenueChart;

  document.getElementById("typeFilter").addEventListener("change", function () {
    loadTopProducts(document.getElementById("frequency").value, this.value);
  });

  document.getElementById("frequency").addEventListener("change", function() {
    loadDashboard(this.value);
  });

  async function loadDashboard(freq = "monthly") {
    await loadRevenue(freq);
    await loadTopProducts(freq, document.getElementById("typeFilter").value);
  }

  async function loadRevenue(freq) {
    const res = await fetch(`/admin/revenue-chart?frequency=${freq}`);
    const data = await res.json();

    /* CARDS */
    document.getElementById("rev").innerText = "₹" + (data.totalRevenue || 0).toLocaleString();
    document.getElementById("sales").innerText = (data.totalSales || 0).toLocaleString();
    document.getElementById("users").innerText = (data.usersCount || 0).toLocaleString();

    /* CHART */
    const labels = data.chartData.map(d => d._id);
    const values = data.chartData.map(d => d.revenue);
    const ctx = document.getElementById("revenueChart").getContext("2d");

    if (revenueChart) revenueChart.destroy();

    const gradient = ctx.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, 'rgba(67, 97, 238, 0.2)');
    gradient.addColorStop(1, 'rgba(67, 97, 238, 0.0)');

    revenueChart = new Chart(ctx, {
      type: "line",
      data: {
        labels,
        datasets: [{
          label: "Revenue",
          data: values,
          borderColor: "#4361ee",
          borderWidth: 3,
          backgroundColor: gradient,
          tension: 0.4,
          fill: true,
          pointBackgroundColor: "#fff",
          pointBorderColor: "#4361ee",
          pointBorderWidth: 2,
          pointRadius: 4,
          pointHoverRadius: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1e293b',
            padding: 12,
            titleFont: { size: 14 },
            bodyFont: { size: 13 },
            displayColors: false,
            callbacks: {
              label: function(context) {
                return 'Revenue: ₹' + context.parsed.y.toLocaleString();
              }
            }
          }
        },
        scales: {
          y: { 
            beginAtZero: true,
            grid: { color: '#f1f5f9' },
            ticks: { color: '#94a3b8', font: { size: 11 } }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#94a3b8', font: { size: 11 } }
          }
        }
      }
    });
  }

  async function loadTopProducts(freq, type = "product") {
    const res = await fetch(`/admin/top-products?frequency=${freq}&type=${type}`);
    const data = await res.json();
    const container = document.getElementById("topProducts");
    container.innerHTML = "";

    if (!data.length) {
      container.innerHTML = `
        <div style="text-align: center; padding: 40px; color: var(--gray-400);">
          <i class="fas fa-folder-open mb-3" style="font-size: 32px; opacity: 0.5; display: block;"></i>
          <p>No sales data available for this range</p>
        </div>
      `;
      return;
    }

    data.forEach(p => {
      container.innerHTML += `
        <div class="progress-item">
          <div class="progress-info">
            <span class="progress-name">${p.name}</span>
            <span class="progress-percent">${p.percentage}%</span>
          </div>
          <div class="progress-bar-bg">
            <div class="progress-bar-fill" style="width: 0%;" data-width="${p.percentage}%"></div>
          </div>
        </div>
      `;
    });

    setTimeout(() => {
      document.querySelectorAll('.progress-bar-fill').forEach(bar => {
        bar.style.width = bar.getAttribute('data-width');
      });
    }, 100);
  }

  /* INITIAL LOAD */
  loadDashboard();
</script>

</body>
</html>