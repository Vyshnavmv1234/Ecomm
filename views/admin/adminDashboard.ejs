<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>WestLane Admin Dashboard</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family: "Inter", Arial, sans-serif;
}

body{
  background:#f6f7fb;
}

.main{
  margin-top:70px;
  margin-left:240px;
  padding:25px;
}
canvas{
  width:100% !important;
  height:100% !important;
}

.progress{
  margin-top:15px;
}

.progress-header{
  display:flex;
  justify-content:space-between;
  font-size:14px;
  margin-bottom:5px;
}

/* STATS */
.stats{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
  margin-bottom:25px;
}

.card{
  background:#fff;
  padding:20px;
  border-radius:16px;
  box-shadow:0 10px 20px rgba(0,0,0,0.04);
}

.card h3{
  margin-top:10px;
  font-size:24px;
}

/* GRID */
.grid{
  display:grid;
  grid-template-columns:2fr 1fr;
  gap:20px;
}

.chart-container{
  height:350px;
  margin-top:20px;
}

.progress{
  margin-top:15px;
}

.progress-header{
  display:flex;
  justify-content:space-between;
  font-size:14px;
}

.bar{
  height:8px;
  background:#e5e7eb;
  border-radius:10px;
}

.bar div{
  height:8px;
  background:#4a5cff;
  border-radius:10px;
}

</style>
</head>

<body>

<!-- HEADER -->
<%- include("../../views/partials/admin/header") %>

<!-- SIDEBAR -->
<%- include("../../views/partials/admin/sidebar") %>

<div class="main">

<h2>Dashboard</h2>

<!-- STATS -->
<div class="stats">

<div class="card">
<p >Total Sales</p>
<h3 id="sales">23</h3>
</div>

<div class="card">
<p>Revenue</p>
<h3 id="rev">₹0</h3>
<small>Profit made so far</small>
</div>

<div class="card">
<p>Users Count</p>
<h3 id="users">0</h3>
<small>Total users</small>
</div>

</div>

<!-- GRID -->
<div class="grid">

<div class="card">

<select id="frequency">
<option value="daily">Daily</option>
<option value="weekly">Weekly</option>
<option value="monthly" selected>Monthly</option>
<option value="yearly">Yearly</option>
</select>

<div class="chart-container">
<canvas id="revenueChart"></canvas>
</div>

</div>

<div class="card">

<p>Most Sold Products</p>

<div id="topProducts"></div>

</div>
</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

let revenueChart;

/* ===============================
   DROPDOWN CHANGE
================================ */
document
.getElementById("frequency")
.addEventListener("change",function(){
  loadDashboard(this.value);
});


/* ===============================
   LOAD COMPLETE DASHBOARD
================================ */
async function loadDashboard(freq="monthly"){

  await loadRevenue(freq);
  await loadTopProducts(freq);

}


/* ===============================
   REVENUE + CARDS
================================ */
async function loadRevenue(freq){

  const res =
    await fetch(`/admin/revenue-chart?frequency=${freq}`);

  const data = await res.json();

  /* ----- CARDS ----- */

  document.getElementById("rev")
    .innerText =
      "₹"+(data.totalRevenue||0).toLocaleString();

  document.getElementById("sales")
    .innerText =
      data.totalSales || 0;

  document.getElementById("users")
    .innerText =
      data.usersCount || 0;


  /* ----- CHART ----- */

  const labels =
    data.chartData.map(d=>d._id);

  const values =
    data.chartData.map(d=>d.revenue);

  const ctx =
    document.getElementById("revenueChart")
    .getContext("2d");

  if(revenueChart)
    revenueChart.destroy();

  revenueChart = new Chart(ctx,{
    type:"line",
    data:{
      labels,
      datasets:[{
        label:"Revenue",
        data:values,
        borderWidth:2,
        tension:0.4,
        fill:true
      }]
    },
    options:{
      responsive:true,
      maintainAspectRatio:false,
      scales:{
        y:{ beginAtZero:true }
      }
    }
  });
}


/* ===============================
   TOP PRODUCTS
================================ */
async function loadTopProducts(freq){

  const res =
    await fetch(`/admin/top-products?frequency=${freq}`);

  const products = await res.json();

  const container =
    document.getElementById("topProducts");

  container.innerHTML="";

  if(!products.length){
    container.innerHTML="<p>No sales data</p>";
    return;
  }

  products.forEach(p=>{

    container.innerHTML += `
      <div class="progress">

        <div class="progress-header">
          <span>${p.name}</span>
          <span>${p.percentage}%</span>
        </div>

        <div class="bar">
          <div style="width:${p.percentage}%"></div>
        </div>

      </div>
    `;
  });

}


/* ===============================
   INITIAL LOAD
================================ */
loadDashboard();

</script>
</body>
</html>