<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>WestLane | Customers</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Global Styles -->
  <%- include("../../views/partials/admin/adminStyles") %>
</head>

<body>

  <!-- HEADER -->
  <%- include("../../views/partials/admin/header") %>

  <!-- SIDEBAR -->
  <%- include("../../views/partials/admin/sidebar") %>

  <div class="layout">
    <div class="content">
      <main class="main">
        
        <!-- PAGE HEADER -->
        <div class="d-flex justify-between align-center mb-4">
          <div>
            <h2>Customer Management</h2>
            <nav class="text-muted d-flex gap-2">
              <a href="/admin/adminDashboard" style="color: var(--primary); text-decoration: none;">Dashboard</a>
              <span>/</span>
              <span>Customers</span>
            </nav>
          </div>
        </div>

        <!-- SEARCH BAR -->
        <div class="card">
          <form method="get" action="/admin/users" class="d-flex justify-center">
            <div class="d-flex gap-2" style="width: 100%; max-width: 600px;">
              <input name="search" type="text" placeholder="Search by name, email or phone..." value="<%= search %>" />
              <button type="submit" class="btn btn-primary">
                <i class="fas fa-search"></i> Search
              </button>
            </div>
          </form>
        </div>

        <!-- CUSTOMERS TABLE -->
        <div class="card">
          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>Customer Name</th>
                  <th>Email Address</th>
                  <th>Phone Number</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!data || data.length === 0) { %>
                  <tr>
                    <td colspan="5" style="text-align:center; padding:40px;">
                      <i class="fas fa-users-slash" style="font-size: 40px; color: var(--gray-300); margin-bottom: 15px; display: block;"></i>
                      <p class="text-muted">No customers found.</p>
                    </td>
                  </tr>
                <% } else { %>
                  <% for (let i = 0; i < data.length; i++) { %>
                    <tr>
                      <td>
                        <div class="d-flex align-center gap-2">
                          <div class="avatar align-center justify-center" style="width: 32px; height: 32px; border-radius: 50%; background: var(--primary-light); color: var(--primary); display: flex; font-weight: 700; font-size: 12px;">
                            <%= data[i].name ? data[i].name.charAt(0).toUpperCase() : 'U' %>
                          </div>
                          <span style="font-weight: 600; color: var(--dark);"><%= data[i].name %></span>
                        </div>
                      </td>
                      <td><%= data[i].email %></td>
                      <td><%= data[i].phone || "—" %></td>
                      <td>
                        <% if (data[i].isBlocked === false) { %>
                          <span class="badge badge-success">Active</span>
                        <% } else { %>
                          <span class="badge badge-danger">Blocked</span>
                        <% } %>
                      </td>
                      <td>
                        <div class="d-flex gap-2">
                          <% if (data[i].isBlocked === false) { %>
                            <button onclick="blockUser('<%= data[i].id %>')" class="btn btn-danger" title="Block User">
                              <i class="fas fa-user-slash"></i> Block
                            </button>
                          <% } else { %>
                            <button onclick="unblockUser('<%= data[i].id %>')" class="btn btn-success" title="Unblock User">
                              <i class="fas fa-user-check"></i> Unblock
                            </button>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% } %>
                <% } %>
              </tbody>
            </table>
          </div>

          <!-- PAGINATION -->
          <% if (totalPages > 1) { %>
            <div class="pagination">
              <% if (currentPage > 1) { %>
                <a href="?page=<%= currentPage - 1 %>&search=<%= search %>" class="page-link">
                  <i class="fas fa-arrow-left"></i>
                </a>
              <% } %>

              <% for (let i = 1; i <= totalPages; i++) { %>
                <a href="?page=<%= i %>&search=<%= search %>" class="page-link <%= i === currentPage ? 'active' : '' %>">
                  <%= i %>
                </a>
              <% } %>

              <% if (currentPage < totalPages) { %>
                <a href="?page=<%= currentPage + 1 %>&search=<%= search %>" class="page-link">
                  <i class="fas fa-arrow-right"></i>
                </a>
              <% } %>
            </div>
          <% } %>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    async function blockUser(userId) {
      const result = await Swal.fire({
        title: "Block this user?",
        text: "User will not be able to login or place orders.",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#ef4444",
        cancelButtonColor: "#64748b",
        confirmButtonText: "Yes, Block",
        cancelButtonText: "Cancel",
        reverseButtons: true
      });

      if (!result.isConfirmed) return;

      Swal.fire({
        title: "Blocking...",
        allowOutsideClick: false,
        didOpen: () => { Swal.showLoading(); }
      });

      try {
        const res = await fetch(`/admin/users/${userId}/block`, { method: "PATCH" });
        const data = await res.json();
        if (data.success) {
          await Swal.fire({ title: "Blocked!", text: "User has been blocked successfully.", icon: "success", confirmButtonColor: "#4361ee" });
          window.location.reload();
        } else {
          throw new Error();
        }
      } catch (err) {
        Swal.fire({ title: "Error!", text: "Failed to block user.", icon: "error", confirmButtonColor: "#ef4444" });
      }
    }
  
    async function unblockUser(userId) {
      const result = await Swal.fire({
        title: "Unblock this user?",
        text: "User will regain full access.",
        icon: "question",
        showCancelButton: true,
        confirmButtonColor: "#10b981",
        cancelButtonColor: "#64748b",
        confirmButtonText: "Yes, Unblock",
        cancelButtonText: "Cancel",
        reverseButtons: true
      });

      if (!result.isConfirmed) return;

      Swal.fire({
        title: "Unblocking...",
        allowOutsideClick: false,
        didOpen: () => { Swal.showLoading(); }
      });

      try {
        const res = await fetch(`/admin/users/${userId}/unblock`, { method: "PATCH" });
        const data = await res.json();
        if (data.success) {
          await Swal.fire({ title: "Unblocked!", text: "User has been unblocked successfully.", icon: "success", confirmButtonColor: "#4361ee" });
          window.location.reload();
        } else {
          throw new Error();
        }
      } catch (err) {
        Swal.fire({ title: "Error!", text: "Failed to unblock user.", icon: "error", confirmButtonColor: "#ef4444" });
      }
    }
  </script>

</body>
</html>
