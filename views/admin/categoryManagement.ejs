<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>WestLane | Categories</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Global Styles -->
  <%- include("../../views/partials/admin/adminStyles") %>
  
  <style>
    .cat-img {
      width: 48px;
      height: 48px;
      object-fit: cover;
      border-radius: 10px;
      background: var(--gray-100);
      border: 1px solid var(--gray-200);
    }
    .search-container { max-width: 400px; }
  </style>
</head>

<body>
  
<div class="layout">
  <!-- SIDEBAR -->
  <%- include("../../views/partials/admin/sidebar") %>

  <!-- CONTENT -->
  <div class="content">
    <!-- HEADER -->
    <%- include("../../views/partials/admin/header") %>

    <!-- MAIN -->
    <main class="main">
      
      <!-- PAGE HEADER -->
      <div class="d-flex justify-between align-center mb-4">
        <div>
          <h2>Category Management</h2>
          <nav class="text-muted d-flex gap-2">
            <a href="/admin/adminDashboard" style="color: var(--primary); text-decoration: none;">Dashboard</a>
            <span>/</span>
            <span>Categories</span>
          </nav>
        </div>
        <a href="/admin/category/new" class="btn btn-primary">
          <i class="fas fa-plus"></i> Create Category
        </a>
      </div>

      <!-- SEARCH -->
      <div class="card">
        <form method="get" action="/admin/category" class="search-container">
          <div class="d-flex gap-2">
            <input name="search" type="text" placeholder="Search categories..." value="<%= search %>" />
            <button type="submit" class="btn btn-outline">
              <i class="fas fa-search"></i>
            </button>
          </div>
        </form>
      </div>

      <!-- CATEGORIES TABLE -->
      <div class="card">
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Category Name</th>
                <th>Status</th>
                <th style="text-align: right;">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (categoryData && categoryData.length > 0) { %>
                <% categoryData.forEach((category) => { %>
                  <tr>
                    <td>
                      <div class="d-flex align-center gap-3">
                        <img src="<%= category.image %>" class="cat-img" alt="<%= category.name %>" onerror="this.src='https://via.placeholder.com/48?text=Cat'" />
                        <div>
                          <div style="font-weight: 600; color: var(--dark);"><%= category.name %></div>
                          <div class="text-muted" style="font-size: 12px;">ID: <%= category._id.toString().slice(-6).toUpperCase() %></div>
                        </div>
                      </div>
                    </td>
                    <td>
                      <% if (category.isBlocked) { %>
                        <span class="badge badge-danger">Blocked</span>
                      <% } else { %>
                        <span class="badge badge-success">Active</span>
                      <% } %>
                    </td>
                    <td>
                      <div class="d-flex gap-2 justify-end">
                        <a href="/admin/editCategory?id=<%=category._id%>" class="btn btn-outline btn-sm" title="Edit">
                          <i class="fas fa-edit"></i> Edit
                        </a>
                        <% if (category.isBlocked) { %>
                          <button onclick="unblockCategory('<%= category._id %>')" class="btn btn-success btn-sm">
                            <i class="fas fa-unlock"></i> Unblock
                          </button>
                        <% } else { %>
                          <button onclick="blockCategory('<%= category._id %>')" class="btn btn-danger btn-sm">
                            <i class="fas fa-ban"></i> Block
                          </button>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="3" style="text-align:center; padding:40px;">
                    <i class="fas fa-folder-open" style="font-size: 40px; color: var(--gray-300); margin-bottom: 15px; display: block;"></i>
                    <p class="text-muted">No categories found match your search.</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- PAGINATION -->
        <% if (totalPages > 1) { %>
          <div class="pagination">
            <% if (currentPage > 1) { %>
              <a class="page-link" href="/admin/category?page=<%= currentPage - 1 %>&search=<%= search %>">
                <i class="fas fa-chevron-left"></i>
              </a>
            <% } %>

            <% for (let i = 1; i <= totalPages; i++) { %>
              <a class="page-link <%= i === currentPage ? 'active' : '' %>" href="/admin/category?page=<%= i %>&search=<%= search %>">
                <%= i %>
              </a>
            <% } %>

            <% if (currentPage < totalPages) { %>
              <a class="page-link" href="/admin/category?page=<%= currentPage + 1 %>&search=<%= search %>">
                <i class="fas fa-chevron-right"></i>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </main>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
async function blockCategory(categoryId){
  const confirmAction = await Swal.fire({
    title: "Block this category?",
    text: "Products under this category will be unavailable.",
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "var(--danger)",
    cancelButtonColor: "var(--gray-500)",
    confirmButtonText: "Yes, Block",
    cancelButtonText: "Cancel",
    reverseButtons: true
  });
  if(!confirmAction.isConfirmed) return;
  try{
    const res = await fetch(`/admin/category/block/${categoryId}`,{ method:"PATCH" });
    const data = await res.json();
    if(data.success){
      await Swal.fire({ icon:"success", title:"Blocked", text:"Category has been blocked", timer:1500, showConfirmButton:false });
      location.reload();
    } else {
      Swal.fire({ icon:"error", title:"Failed", text:data.message || "Failed to block category" });
    }
  } catch(error){
    console.error(error);
    Swal.fire({ icon:"error", title:"Server Error", text:"Something went wrong" });
  }
}

async function unblockCategory(categoryId){
  const confirmAction = await Swal.fire({
    title: "Unblock this category?",
    text: "Products will become available again.",
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "var(--success)",
    cancelButtonColor: "var(--gray-500)",
    confirmButtonText: "Yes, Unblock",
    cancelButtonText: "Cancel",
    reverseButtons: true
  });
  if(!confirmAction.isConfirmed) return;
  try{
    const res = await fetch(`/admin/category/unblock/${categoryId}`,{ method:"PATCH" });
    const data = await res.json();
    if(data.success){
      await Swal.fire({ icon:"success", title:"Unblocked", text:"Category has been unblocked", timer:1500, showConfirmButton:false });
      location.reload();
    } else {
      Swal.fire({ icon:"error", title:"Failed", text:data.message || "Failed to unblock category" });
    }
  } catch(error){
    console.error(error);
    Swal.fire({ icon:"error", title:"Server Error", text:"Something went wrong" });
  }
}
</script>

</body>
</html>
