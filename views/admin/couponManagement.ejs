<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>WestLane | Coupons</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Global Styles -->
  <%- include("../../views/partials/admin/adminStyles") %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  
  <style>
    .search-container { max-width: 350px; }
    .coupon-code {
      font-family: 'Monaco', 'Consolas', monospace;
      background: var(--gray-100);
      padding: 4px 8px;
      border-radius: 6px;
      color: var(--primary);
      font-weight: 700;
      letter-spacing: 1px;
    }
    /* Fix for overlapping elements blocking clicks */
    .content { position: relative; z-index: 1; }
    .card { position: relative; z-index: 2; }
    .btn { position: relative; z-index: 5; }
  </style>
</head>

<body>
  
<div class="layout">
  <!-- SIDEBAR -->
  <%- include("../../views/partials/admin/sidebar") %>

  <!-- CONTENT -->
  <div class="content">
    <!-- HEADER -->
    <%- include("../../views/partials/admin/header") %>

    <!-- MAIN -->
    <main class="main">
      
      <!-- PAGE HEADER -->
      <div class="d-flex justify-between align-center mb-4">
        <div>
          <h2>Coupon Management</h2>
          <nav class="text-muted d-flex gap-2">
            <a href="/admin/adminDashboard" style="color: var(--primary); text-decoration: none;">Dashboard</a>
            <span>/</span>
            <span>Coupons</span>
          </nav>
        </div>
        <button onclick="openCouponModal()" class="btn btn-primary">
          <i class="fas fa-plus"></i> Add New Coupon
        </button>
      </div>

      <!-- SEARCH -->
      <div class="card">
        <form method="get" action="/admin/coupon/couponManagement" class="search-container">
          <div class="d-flex gap-2">
            <input name="search" type="text" placeholder="Search coupon code..." value="<%= search || '' %>" />
            <button type="submit" class="btn btn-outline">
              <i class="fas fa-search"></i>
            </button>
          </div>
        </form>
      </div>

      <!-- COUPONS TABLE -->
      <div class="card">
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Code</th>
                <th>Discount Value</th>
                <th>Min Order</th>
                <th>Expiry Date</th>
                <th>Status</th>
                <th style="text-align: right;">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (coupons && coupons.length > 0) { %>
                <% coupons.forEach(function(coupon){ %>
                  <tr>
                    <td><span class="coupon-code"><%= coupon.code %></span></td>
                    <td style="font-weight: 600; color: var(--dark);">
                      <%= coupon.discountType === "percentage" ? coupon.discountValue + "%" : "₹" + coupon.discountValue.toLocaleString() %>
                    </td>
                    <td>₹<%= coupon.minOrderAmount.toLocaleString() %></td>
                    <td class="text-muted">
                      <%= coupon.expireDate ? new Date(coupon.expireDate).toLocaleDateString("en-IN") : "N/A" %>
                    </td>
                    <td>
                      <% if (coupon.isActive) { %>
                        <span class="badge badge-success">Active</span>
                      <% } else { %>
                        <span class="badge badge-danger">Inactive</span>
                      <% } %>
                    </td>
                    <td>
                      <div class="d-flex gap-2 justify-end">
                        <button class="btn btn-outline btn-sm" onclick='openEditModal(<%- JSON.stringify({
                          id: coupon._id,
                          code: coupon.code,
                          discount: coupon.discountValue,
                          min: coupon.minOrderAmount,
                          expire: coupon.expireDate,
                          limit: coupon.usageLimit || ""
                        }) %>)'>
                          <i class="fas fa-edit"></i> Edit
                        </button>
                        <% if (!coupon.isActive) { %>
                          <button onclick="enableCoupon('<%= coupon._id %>')" class="btn btn-success btn-sm">
                            <i class="fas fa-play"></i> Enable
                          </button>
                        <% } else { %>
                          <button onclick="disableCoupon('<%= coupon._id %>')" class="btn btn-danger btn-sm">
                            <i class="fas fa-pause"></i> Disable
                          </button>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" style="text-align:center; padding:40px;">
                    <i class="fas fa-ticket-alt" style="font-size: 40px; color: var(--gray-300); margin-bottom: 15px; display: block;"></i>
                    <p class="text-muted">No coupons found.</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- PAGINATION -->
        <% if (totalPages > 1) { %>
          <div class="pagination">
            <% if (currentPage > 1) { %>
              <a class="page-link" href="/admin/coupon/couponManagement?page=<%= currentPage - 1 %>&search=<%= search %>">
                <i class="fas fa-chevron-left"></i>
              </a>
            <% } %>

            <% for (let i = 1; i <= totalPages; i++) { %>
              <a class="page-link <%= currentPage === i ? 'active' : '' %>" href="/admin/coupon/couponManagement?page=<%= i %>&search=<%= search %>">
                <%= i %>
              </a>
            <% } %>

            <% if (currentPage < totalPages) { %>
              <a class="page-link" href="/admin/coupon/couponManagement?page=<%= currentPage + 1 %>&search=<%= search %>">
                <i class="fas fa-chevron-right"></i>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </main>
  </div>
</div>

<!-- ADD COUPON MODAL -->
<div id="couponModal" class="modal">
  <div class="modal-content" style="max-width: 500px;">
    <span class="close" onclick="closeCouponModal()">&times;</span>
    <div class="modal-header mb-4">
      <h3>Create New Coupon</h3>
      <p class="text-muted" style="font-size: 0.875rem;">Set up a new discount code for your customers.</p>
    </div>
    <form id="addCouponForm">
      <div class="form-group">
        <label>Coupon Code</label>
        <input type="text" name="code" placeholder="e.g. WELCOME20" required style="text-transform: uppercase;">
      </div>
      <div class="form-group">
        <label>Discount Value</label>
        <div class="d-flex gap-2">
           <input type="number" name="discountValue" placeholder="Amount" required style="flex: 2;">
           <select name="discountType" style="flex: 1;">
              <option value="percentage">%</option>
              <option value="flat">₹</option>
           </select>
        </div>
      </div>
      <div class="form-group">
        <label>Minimum Purchase (₹)</label>
        <input type="number" name="minOrderAmount" placeholder="e.g. 500" required>
      </div>
      <div class="d-flex gap-3">
        <div class="form-group" style="flex: 1;">
          <label>Expiry Date</label>
          <input type="date" name="expireDate" required>
        </div>
        <div class="form-group" style="flex: 1;">
          <label>Usage Limit</label>
          <input type="number" name="usageLimit" value="100" min="1">
        </div>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closeCouponModal()">Cancel</button>
        <button type="submit" class="btn btn-primary" style="flex: 2;">Save Coupon</button>
      </div>
    </form>
  </div>
</div>

<!-- EDIT COUPON MODAL -->
<div id="editCouponModal" class="modal">
  <div class="modal-content" style="max-width: 500px;">
    <span class="close" onclick="closeEditModal()">&times;</span>
    <div class="modal-header mb-4">
      <h3>Edit Coupon</h3>
      <p class="text-muted" style="font-size: 0.875rem;">Modify the details of your existing coupon code.</p>
    </div>
    <form id="editCouponForm">
      <div class="form-group">
        <label>Coupon Code</label>
        <input type="text" name="code" id="editCode" required style="text-transform: uppercase;">
      </div>
      <div class="form-group">
        <label>Discount Value</label>
        <input type="number" name="discountValue" id="editDiscount" required>
      </div>
      <div class="form-group">
        <label>Minimum Purchase (₹)</label>
        <input type="number" name="minOrderAmount" id="editMinOrder" required>
      </div>
      <div class="d-flex gap-3">
        <div class="form-group" style="flex: 1;">
          <label>Expiry Date</label>
          <input type="date" name="expireDate" id="editExpireDate" required>
        </div>
        <div class="form-group" style="flex: 1;">
          <label>Usage Limit</label>
          <input type="number" name="usageLimit" id="editUsageLimit">
        </div>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closeEditModal()">Cancel</button>
        <button type="submit" class="btn btn-primary" style="flex: 2;">Update Coupon</button>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

<script>
/* TOAST FUNCTION */
function showToast(message, type = "success") {
  const colors = { success: "#10b981", error: "#ef4444", warning: "#f59e0b", info: "#3b82f6" };
  Toastify({
    text: message,
    duration: 3000,
    gravity: "bottom",
    position: "center",
    close: true,
    style: { background: colors[type] || colors.info, borderRadius: "12px", fontSize: "14px" } 
  }).showToast();
}

function validateCoupon(formData) {
  const { code, discountValue, minOrderAmount, expireDate, usageLimit } = formData;
  if (!code || code.trim().length < 3) { showToast("Code must be at least 3 chars", "error"); return false; }
  if (isNaN(discountValue) || discountValue <= 0) { showToast("Discount must be positive", "error"); return false; }
  if (isNaN(minOrderAmount) || minOrderAmount <= 0) { showToast("Min order must be positive", "error"); return false; }
  if (discountValue >= minOrderAmount) { showToast("Discount cannot exceed amount", "error"); return false; }
  if (!expireDate) { showToast("Expiry date required", "error"); return false; }
  const today = new Date(); today.setHours(0,0,0,0);
  if (new Date(expireDate) < today) { showToast("Expiry cannot be in past", "error"); return false; }
  
  if (usageLimit !== undefined && usageLimit !== "") {
    const limit = Number(usageLimit);
    if (isNaN(limit) || limit < 0) {
      showToast("Usage limit must be a positive number", "error");
      return false;
    }
  }
  return true;
}

/* MODAL CONTROLS */
function openCouponModal(){ document.getElementById("couponModal").style.display="flex"; }
function closeCouponModal(){ document.getElementById("couponModal").style.display="none"; }
function closeEditModal(){ document.getElementById("editCouponModal").style.display="none"; }
window.onclick = function(e){
  if(e.target.classList.contains('modal')) e.target.style.display="none";
};

/* ADD COUPON */
const addForm = document.getElementById("addCouponForm");
if(addForm){
  addForm.addEventListener("submit", async function(e){
    e.preventDefault();
    const formData = {
      code: addForm.code.value.trim().toUpperCase(),
      discountValue: Number(addForm.discountValue.value),
      minOrderAmount: Number(addForm.minOrderAmount.value),
      expireDate: addForm.expireDate.value,
      usageLimit: addForm.usageLimit.value
    };
    if(!validateCoupon(formData)) return;
    try {
      const res = await fetch("/admin/coupon/createCoupon", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({...formData, usageLimit: formData.usageLimit !== "" ? Number(formData.usageLimit) : 1})
      });
      const result = await res.json();
      if(result.success){
        showToast(result.message || "Coupon created successfully","success");
        setTimeout(()=> location.reload(), 1000);
      } else showToast(result.message,"error");
    } catch(err){ showToast("Server error","error"); }
  });
}

function openEditModal(coupon){
  document.getElementById("editCouponModal").style.display="flex";
  document.getElementById("editCode").value = coupon.code?.trim() || "";
  document.getElementById("editDiscount").value = coupon.discount || "";
  document.getElementById("editMinOrder").value = coupon.min || "";
  document.getElementById("editUsageLimit").value = coupon.limit || "";
  if(coupon.expire) document.getElementById("editExpireDate").value = new Date(coupon.expire).toISOString().split("T")[0];
  document.getElementById("editCouponForm").dataset.id = coupon.id;
}

const editForm = document.getElementById("editCouponForm");
if(editForm){
  editForm.addEventListener("submit", async function(e){
    e.preventDefault();
    const couponId = editForm.dataset.id;
    const formData = {
      code: editForm.code.value.trim().toUpperCase(),
      discountValue: Number(editForm.discountValue.value),
      minOrderAmount: Number(editForm.minOrderAmount.value),
      expireDate: editForm.expireDate.value,
      usageLimit: editForm.usageLimit.value
    };
    if(!validateCoupon(formData)) return;
    try {
      const res = await fetch(`/admin/coupon/updateCoupon/${couponId}`, {
        method:"PATCH",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({...formData, usageLimit: formData.usageLimit !== "" ? Number(formData.usageLimit) : 1})
      });
      const result = await res.json();
      if(result.success){
        showToast(result.message || "Coupon updated successfully","success");
        setTimeout(()=> location.reload(), 1000);
      } else showToast(result.message,"error");
    } catch(err){ showToast("Server error","error"); }
  });
}

/* TOGGLE STATUS */
async function toggleCoupon(url, message){
  const result = await Swal.fire({
    title: message, icon: "warning", showCancelButton: true,
    confirmButtonColor: "var(--primary)", cancelButtonColor: "var(--danger)",
    confirmButtonText: "Yes", reverseButtons: true
  });
  if(!result.isConfirmed) return;
  try {
    const res = await fetch(url,{method:"PATCH"});
    const data = await res.json();
    if(data.success){
      await Swal.fire({ icon:"success", title:"Updated", text:data.message, timer:1500, showConfirmButton:false });
      location.reload();
    } else Swal.fire({ icon:"error", title:"Error", text:data.message });
  } catch(err){ Swal.fire({ icon:"error", title:"Server Error", text:"Something went wrong" }); }
}
function disableCoupon(id){ toggleCoupon(`/admin/coupon/disableCoupon/${id}`, "Disable this coupon?"); }
function enableCoupon(id){ toggleCoupon(`/admin/coupon/enableCoupon/${id}`, "Enable this coupon?"); }
</script>

</body>
</html>
