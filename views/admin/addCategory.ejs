<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>WestLane | Add Category</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<%- include("../../views/partials/admin/adminStyles") %>

<style>
/* CUSTOM PAGE STYLES */
.form-grid {
  margin-top: 22px;
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 24px;
}

.upload-box {
  border: 2px dashed var(--gray-200);
  border-radius: 14px;
  padding: 30px 16px;
  text-align: center;
  background: var(--gray-50);
  cursor: pointer;
  transition: var(--transition);
}

.upload-box:hover {
  border-color: var(--primary);
  background: white;
}

#preview {
  width: 100%;
  max-height: 200px;
  object-fit: contain;
  border-radius: 8px;
  margin-bottom: 12px;
}

@media (max-width: 1024px) {
  .form-grid { grid-template-columns: 1fr; }
}
</style>
</head>

<body>
  
<div class="layout">
  <!-- SIDEBAR -->
  <%- include("../../views/partials/admin/sidebar") %>

  <!-- CONTENT -->
  <div class="content">
    <!-- HEADER -->
    <%- include("../../views/partials/admin/header") %>

    <!-- MAIN -->
    <main class="main">
      <div class="d-flex justify-between align-center mb-4">
        <div>
          <h2>Add Category</h2>
          <nav class="text-muted d-flex gap-2">
            <a href="/admin/category" style="color: var(--primary); text-decoration: none;">Categories</a>
            <span>/</span>
            <span>Create New</span>
          </nav>
        </div>
        <div class="d-flex gap-2">
          <a href="/admin/category" class="btn btn-outline">Cancel</a>
          <button type="button" id="addCategoryBtn" class="btn btn-primary">
            <i class="fas fa-check"></i> Save Category
          </button>
        </div>
      </div>

      <!-- FORM CONTENT -->
      <div class="form-grid">
        <!-- THUMBNAIL -->
        <div class="card">
          <h4 class="mb-3">Category Image</h4>
          <p class="text-muted mb-3" style="font-size: 13px;">This image will represent the category on the store.</p>
          
          <input type="file" name="image" id="imageInput" hidden accept="image/*" />
          
          <div class="upload-box" onclick="document.getElementById('imageInput').click()">
            <img id="preview" style="display:none;">
            <div id="uploadPrompt">
              <i class="fas fa-cloud-upload-alt fa-2x mb-2" style="color: var(--gray-400);"></i>
              <p style="font-size: 14px; font-weight: 500;">Click to upload</p>
              <p class="text-muted" style="font-size: 12px;">PNG, JPG up to 5MB</p>
            </div>
          </div>
        </div>

        <!-- GENERAL INFO -->
        <div class="card">
          <h4 class="mb-4">General Information</h4>
          <div class="form-group">
            <label for="categoryName">Category Name</label>
            <input id="categoryName" type="text" placeholder="e.g. Men's Footwear" />
            <small id="errorMsg" style="color:var(--danger); display:block; margin-top:8px;"></small>
            <small id="successMsg" style="color:var(--success); display:block; margin-top:8px;"></small>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<script>
const addBtn = document.getElementById("addCategoryBtn")
const categoryInput = document.getElementById("categoryName")
const imageInput = document.getElementById("imageInput")
const errorMsg = document.getElementById("errorMsg")
const successMsg = document.getElementById("successMsg")
const preview = document.getElementById("preview")
const uploadPrompt = document.getElementById("uploadPrompt")

imageInput.addEventListener("change", () => {
  const file = imageInput.files[0]
  if (file) {
    preview.src = URL.createObjectURL(file)
    preview.style.display = "block"
    uploadPrompt.style.display = "none"
  }
})

addBtn.addEventListener("click", async () => {
  errorMsg.textContent = ""
  successMsg.textContent = ""

  const name = categoryInput.value.trim()
  const imageFile = imageInput.files[0]

  if (!name) { errorMsg.textContent = "Category name is required"; return; }
  if (name.length < 3) { errorMsg.textContent = "Category name must be at least 3 characters"; return; }
  if (!imageFile) { errorMsg.textContent = "Category image is required"; return; }

  addBtn.disabled = true
  addBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

  try {
    const formData = new FormData()
    formData.append("categoryName", name)
    formData.append("image", imageFile)

    const res = await fetch("/admin/add-category", {
      method: "POST",
      body: formData
    })

    const data = await res.json()
    if (!res.ok) throw new Error(data.error || "Failed to add category")

    successMsg.textContent = "Category added successfully!"
    setTimeout(() => { window.location.href = "/admin/category" }, 1000)
  } catch (err) {
    errorMsg.textContent = err.message
    addBtn.disabled = false
    addBtn.innerHTML = '<i class="fas fa-check"></i> Save Category';
  }
})
</script>
</body>
</html>
